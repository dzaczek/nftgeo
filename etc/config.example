# AbuseIPDB API key. Create one in the AbuseIPDB account panel.
# The blacklist is only downloaded and applied when a rule targets "abuse"
# (e.g. "deny in any - abuse" in rules.conf). Without this key, nftgeo still
# builds the geo rules, but any abuse rule matches an empty set.
ABUSEIPDB_API_KEY=""

# AbuseIPDB blacklist filters.
ABUSEIPDB_CONFIDENCE_MINIMUM="90"
ABUSEIPDB_LIMIT="10000"
ABUSEIPDB_DAYS="30"

# Keep IPs previously downloaded from AbuseIPDB for this many days after they
# were last seen in a successful API response. Set to 30, 60, etc. Defaults to
# ABUSEIPDB_DAYS when omitted.
ABUSEIPDB_RETENTION_DAYS="30"

# Extra plaintext IP/CIDR blocklists merged into the same "abuse" sets, so any
# "deny ... abuse" rule covers them too. Space- or newline-separated URLs, only
# fetched when a rule targets "abuse". Each feed's last good copy is cached and
# reused if a later download fails. Mind feed quality: conservative lists
# (FireHOL level1, Spamhaus DROP) have few false positives; broader ones
# (blocklist.de, GreenSnow) block more but can catch legitimate traffic - the
# WHITELIST always wins over abuse. Example:
# ABUSE_FEEDS="https://iplists.firehol.org/files/firehol_level1.netset
# https://www.spamhaus.org/drop/drop.txt
# https://lists.blocklist.de/lists/all.txt
# https://blocklist.greensnow.co/greensnow.txt"
ABUSE_FEEDS=""

# Max entries kept from a single abuse feed. A runaway list (millions of IPs)
# builds a huge nftables set that is slow to load and query; cap it to what the
# box can handle. 0 disables the cap. Default 200000.
ABUSE_FEEDS_MAX="200000"

# Collapse abuse IPs into CIDR ranges before loading. Shrinks the nftables set
# (adjacent /32s become one prefix) so it loads and matches faster. Uses the
# `iprange` tool (IPv4) / `aggregate6` (IPv6) when present; falls back to the
# kernel's set auto-merge otherwise. 1 = on (default), 0 = off.
ABUSE_FEEDS_AGGREGATE="1"

# Load a large abuse set in paced batches instead of all at once, so a huge
# blocklist can't spike load average on a small box. When the set has more than
# this many entries, the ruleset loads with an empty abuse set and the engine
# fills it in chunks of this size, pausing ABUSE_FEEDS_BATCH_SLEEP seconds
# between chunks. Protection ramps up over the load window. 0 = off (default,
# load everything atomically). The dashboard shows a progress bar while filling.
ABUSE_FEEDS_BATCH="0"
ABUSE_FEEDS_BATCH_SLEEP="1"

# Always-allow list. These addresses can reach any port even when they are
# outside an allowed geo or appear on the AbuseIPDB blacklist.
#
# Preferred: put entries in /etc/nftgeo/whitelist.conf (one IP/CIDR per line,
# # comments allowed). The file is read by the engine and editable via the UI
# dashboard's Whitelist tab with full draft → commit → deadman safety.
#
# Legacy: WHITELIST= here still works (space-separated) for backward compat.
# The file is preferred once it has any entry; WHITELIST= is used only when the
# file is empty/absent. Example:
# WHITELIST="203.0.113.10 198.51.100.0/24 2001:db8::/48"
WHITELIST=""

# Hostnames to keep whitelisted by name (WHITELIST only accepts literal IPs).
# Each is resolved to its IPs on every run, so the systemd timer re-resolves them
# periodically, and the addresses are merged into the whitelist above.
#
# Preferred: put entries in /etc/nftgeo/whitelist-hosts.conf (one per line).
# Legacy: WHITELIST_HOSTS= here still works (space-separated); used only when the
# file is empty/absent. Example:
# WHITELIST_HOSTS="wireguard.example.ch vpn.example.net"
WHITELIST_HOSTS=""

# Keep a whitelist host's last successfully resolved addresses for this many days
# when a lookup fails, so a transient DNS outage cannot drop your access. A
# successful lookup replaces the old addresses; unresolved ones age out after
# this window.
WHITELIST_HOSTS_RETENTION_DAYS="7"

# Resolvers tried for WHITELIST_HOSTS, in order; the first that returns an address
# wins. "local" is the system resolver (getent); an IP queries that DNS server
# directly (needs dig, host, or nslookup installed). Listing public servers
# before "local" keeps hostname whitelisting working even when the local/VPN
# resolver is down, and gives the public-facing address (usually what the box
# sees as your source). Example:
# RESOLVERS="1.1.1.1 8.8.8.8 local"
RESOLVERS="local"
RESOLVE_TIMEOUT="5"

# How long a downloaded country zone is reused before being refreshed, in hours.
# The systemd timer runs twice a day; with 20h the early run downloads and the
# later run reuses the cache.
ZONE_CACHE_HOURS="20"

# Log dropped packets to the kernel log / journald. Set to any non-empty value to
# emit a rate-limited 'log prefix "nftgeo-drop "' before every drop rule; view
# with: journalctl -k | grep nftgeo-drop. Off by default.
#
# Note: LOG_DROPS generates up to 10 log entries/second (configurable via
# LOG_LIMIT). Over time these accumulate in journald. To limit retention, create
# /etc/systemd/journald.conf.d/nftgeo.conf:
#   [Journal]
#   MaxRetentionSec=7day
# Then: systemctl restart systemd-journald
LOG_DROPS=""

# Baseline hardening on every managed chain. Set to any non-empty value to accept
# loopback traffic, drop invalid conntrack state, and always permit the ICMPv6
# types IPv6 needs (so fencing v6 cannot break Neighbor Discovery). Off by default.
HARDEN=""

# Anti-spoofing: drop packets whose source address is not routable back
# through the interface they arrived on (reverse-path filter, like rp_filter
# but in the firewall). Space-separated list of interfaces to protect.
# Example: ANTISPOOF="eth0"  (protect the WAN from LAN-spoofed source IPs)
# Needs kernel >= 4.1 (nftables fib expression). IPv4 only; IPv6 uses the
# ndisc/ neighbor cache and is not affected.
ANTISPOOF=""

# Input chain default policy. "accept" (default) = selective blocklist: only what
# your rules explicitly deny (geo/abuse/throttle) is dropped, everything else
# passes. Note: rules are evaluated in file order (first match wins) and a
# geo-restricted "allow in" does NOT auto-close its port — anything not matched
# falls through to this accept policy. Add a catch-all "deny in <proto> <port>
# any" after such an allow, or use "drop" below. validate warns about ports left
# open this way.
# "drop" = default-deny (recommended when you geo-fence inbound ports): only
# established/related, loopback, WHITELIST and your explicit "allow in" rules get
# in; all other new inbound connections are dropped. MAKE SURE an
# "allow in tcp 22 <src>" or WHITELIST admits your SSH before enabling, and
# deploy behind the deadman (nftgeo apply --confirm).
# DEFAULT_INPUT="drop"

# Default ban duration for "throttle" rules (reactive brute-force auto-block): a
# source that exceeds the rate is dropped for this long. Per-rule override with
# "ban <dur>". Format: N[smhd], e.g. 30m, 1h, 2d.
# THROTTLE_BAN="1h"

# Region macros referenced by name in rules.conf. Values are ISO 3166-1 alpha-2
# lowercase codes. The following regions are built in and need no entry here:
#   europe, north_america, caribbean, south_america, middle_east, asia,
#   africa, oceania
#
# Override a built-in by redefining it below (this example trims Russia and
# Belarus from Europe), or add your own REGION_<NAME>; the name used in
# rules.conf is the lowercased part after REGION_ (e.g. REGION_NORDICS -> nordics).
#
# REGION_EUROPE="ad al at ax ba be bg ch cy cz de dk ee es fi fo fr gb ge gg gi gr hr hu ie im is it je li lt lu lv mc md me mk mt nl no pl pt ro rs se si sk sm ua va"
# REGION_NORDICS="dk fi is no se"

# Named address groups, referenced by name in rules.conf. A group is a reusable
# list that may mix literal IPv4/IPv6 addresses, subnets, country codes, and
# region names. Use the lowercased part after GROUP_ in a rule (GROUP_OFFICE ->
# office). A GROUP_/REGION_ name takes precedence over a country code of the same
# name. Examples:
# Groups cannot reference other groups.
# GROUP_OFFICE="203.0.113.5 198.51.100.0/24 2001:db8:1::/48"
# GROUP_ADMINS="203.0.113.10 10.0.0.0/8"
# GROUP_PARTNERS="de fr 192.0.2.0/24"
#
# Host labels: name a single IP/CIDR and use the name as a rule target (like a
# one-address group). Use the lowercased part after HOST_ (HOST_DB1 -> db1).
# HOST_DB1="10.0.20.5"
# HOST_LB="10.0.10.7 10.0.10.8"
#
# Named service objects, referenced by name in a rule's PORT field. A service is
# a reusable list of ports, ranges, and/or other service names (nested). Use the
# lowercased part after SERVICE_ in a rule (SERVICE_WEB -> web). Examples:
# SERVICE_WEB="80 443"
# SERVICE_MAIL="25 465 587 993"
# SERVICE_STACK="web 8080-8090"        # services can nest other services
# SERVICE_DNS="53/tcp 53/udp"          # a member may carry a /tcp or /udp proto
#   A bare port takes the rule's protocol (all/any -> both tcp+udp); a /proto-
#   tagged port is fixed. Use 'allow in any dns any' to emit every proto it defines.
#
# Zones (internal firewall / segmentation): name a network segment as a list of
# interfaces (including VLAN subinterfaces like eth0.100). Use the lowercased part
# after ZONE_ in an inter-zone rule (ZONE_LAN -> lan). Inter-zone rules live in
# rules.conf as "allow|deny <zone> -> <zone> <proto> <port> [from <geo>]" and are
# emitted into the forward chain (needs net.ipv4.ip_forward=1). Examples:
# ZONE_LAN="eth1"
# ZONE_DMZ="eth2"
# ZONE_GUEST="eth0.100"                 # a VLAN subinterface is just an interface
#
# Inter-zone default. "" (default) leaves forwarding between zones open except
# where a rule denies it; "deny" drops all forwarded traffic between zone
# interfaces that no "allow ... -> ..." rule permits (micro-segmentation). Enable
# behind the deadman on a live gateway.
# SEGMENT_DEFAULT="deny"
