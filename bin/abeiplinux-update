#!/bin/sh
set -eu

CONFIG_FILE="${CONFIG_FILE:-/etc/abeiplinux/abeiplinux.conf}"
RULES_FILE="${RULES_FILE:-/etc/abeiplinux/rules.conf}"
STATE_DIR="${STATE_DIR:-/var/lib/abeiplinux}"
ZONE_DIR="${ZONE_DIR:-${STATE_DIR}/zones}"
NFT_FILE="${NFT_FILE:-/etc/nftables.d/abeiplinux.nft}"
TABLE_FAMILY="${TABLE_FAMILY:-inet}"
TABLE_NAME="${TABLE_NAME:-abeiplinux}"
WHITELIST="${WHITELIST:-}"
ZONE_CACHE_HOURS="${ZONE_CACHE_HOURS:-20}"

ABUSEIPDB_API_KEY="${ABUSEIPDB_API_KEY:-}"
ABUSEIPDB_CONFIDENCE_MINIMUM="${ABUSEIPDB_CONFIDENCE_MINIMUM:-90}"
ABUSEIPDB_LIMIT="${ABUSEIPDB_LIMIT:-10000}"
ABUSEIPDB_DAYS="${ABUSEIPDB_DAYS:-30}"
ABUSEIPDB_URL="${ABUSEIPDB_URL:-https://api.abuseipdb.com/api/v2/blacklist}"

IPDENY_V4_URL="${IPDENY_V4_URL:-https://www.ipdeny.com/ipblocks/data/aggregated}"
IPDENY_V6_URL="${IPDENY_V6_URL:-https://www.ipdeny.com/ipv6/ipaddresses/aggregated}"

# Default region macros. Referenced by name in rules.conf. Override or add your
# own REGION_<NAME> variables in the config file.
REGION_EUROPE="${REGION_EUROPE:-ad al am at ax az ba be bg by ch cy cz de dk ee es fi fo fr gb ge gg gi gr hr hu ie im is it je li lt lu lv mc md me mk mt nl no pl pt ro rs ru se si sk sm tr ua va xk}"
REGION_NORTH_AMERICA="${REGION_NORTH_AMERICA:-us ca mx bz cr gt hn ni pa sv}"
REGION_CARIBBEAN="${REGION_CARIBBEAN:-ag ai aw bb bs bl bm bq cu cw dm do gd gp ht jm kn ky lc mf mq ms pr sx tc tt vc vg vi}"
REGION_SOUTH_AMERICA="${REGION_SOUTH_AMERICA:-ar bo br cl co ec fk gf gy pe py sr uy ve}"
REGION_MIDDLE_EAST="${REGION_MIDDLE_EAST:-ae bh il iq ir jo kw lb om ps qa sa sy tr ye}"
REGION_ASIA="${REGION_ASIA:-af bd bn bt cn id in jp kg kh kp kr kz la lk mm mn mv my np ph pk sg th tj tl tm tw uz vn}"
REGION_AFRICA="${REGION_AFRICA:-ao bf bi bj bw cd cf cg ci cm cv dj dz eg eh er et ga gh gm gn gq gw ke km lr ls ly ma mg ml mr mu mw mz na ne ng rw sc sd sl sn so ss st sz td tg tn tz ug za zm zw}"
REGION_OCEANIA="${REGION_OCEANIA:-au fj fm ki mh nc nr nz pf pg pw sb to tv vu ws}"

TMP_DIR="$(mktemp -d)"
cleanup() {
	rm -rf "$TMP_DIR"
}
trap cleanup EXIT

if [ "$(id -u)" -ne 0 ]; then
	echo "Run as root." >&2
	exit 1
fi

if [ -r "$CONFIG_FILE" ]; then
	. "$CONFIG_FILE"
fi

if [ ! -r "$RULES_FILE" ]; then
	echo "Rules file not found: ${RULES_FILE}" >&2
	exit 1
fi

mkdir -p "$STATE_DIR" "$ZONE_DIR" "$(dirname "$NFT_FILE")"

IPV4_RE='^([0-9]{1,3}\.){3}[0-9]{1,3}(/[0-9]{1,2})?$'
IPV6_RE='^[0-9a-fA-F:]+(/[0-9]{1,3})?$'
TAB="$(printf '\t')"

RULES_NORM="${TMP_DIR}/rules.norm"
GEO_TOKENS="${TMP_DIR}/geo.tokens"
GEO_FINAL="${TMP_DIR}/geo.final"
NEEDED_CC="${TMP_DIR}/cc.needed"

sanitize_lower() {
	printf '%s' "$1" | tr 'A-Z' 'a-z' | tr -cs 'a-z0-9' '_' | sed 's/^_//; s/_*$//'
}

resolve_region() {
	u="$(printf '%s' "$1" | tr 'a-z' 'A-Z' | tr -cs 'A-Z0-9_' '_')"
	eval "printf '%s' \"\${REGION_${u}:-}\""
}

resolve_geo() {
	# Expand a comma-separated geo spec into sorted unique country codes.
	out=""
	oldifs=$IFS
	IFS=','
	for tok in $1; do
		IFS=$oldifs
		tok="$(printf '%s' "$tok" | tr 'A-Z' 'a-z' | tr -d '[:space:]')"
		if [ -z "$tok" ]; then
			IFS=','
			continue
		fi
		region="$(resolve_region "$tok")"
		if [ -n "$region" ]; then
			out="$out $region"
		else
			case "$tok" in
				[a-z][a-z]) out="$out $tok" ;;
				*) return 1 ;;
			esac
		fi
		IFS=','
	done
	IFS=$oldifs
	# shellcheck disable=SC2086
	printf '%s\n' $out | sort -u | tr '\n' ' '
}

emit_norm() {
	printf '%s %s %s %s %s\n' "$1" "$2" "$3" "$4" "$5" >> "$RULES_NORM"
}

parse_rules() {
	: > "$RULES_NORM"
	: > "$GEO_TOKENS"
	: > "$NEEDED_CC"

	lineno=0
	while IFS=" ${TAB}" read -r action dir proto port geo _rest; do
		lineno=$((lineno + 1))
		case "$action" in ''|\#*) continue ;; esac

		case "$action" in
			allow|deny) ;;
			*) echo "${RULES_FILE}:${lineno}: bad action '${action}'" >&2; exit 1 ;;
		esac
		case "$dir" in
			in|out) ;;
			*) echo "${RULES_FILE}:${lineno}: bad direction '${dir}' (use in|out)" >&2; exit 1 ;;
		esac
		case "$proto" in
			tcp|udp|all) ;;
			*) echo "${RULES_FILE}:${lineno}: bad proto '${proto}' (use tcp|udp|all)" >&2; exit 1 ;;
		esac
		case "$port" in
			''|*[!0-9]*) echo "${RULES_FILE}:${lineno}: bad port '${port}'" >&2; exit 1 ;;
		esac
		if [ -z "$geo" ]; then
			echo "${RULES_FILE}:${lineno}: missing geo" >&2
			exit 1
		fi

		if [ "$geo" = "any" ]; then
			geosan="any"
		else
			if ! countries="$(resolve_geo "$geo")"; then
				echo "${RULES_FILE}:${lineno}: bad geo '${geo}'" >&2
				exit 1
			fi
			countries="$(printf '%s' "$countries" | sed 's/^ *//; s/ *$//')"
			if [ -z "$countries" ]; then
				echo "${RULES_FILE}:${lineno}: geo '${geo}' resolved to nothing" >&2
				exit 1
			fi
			geosan="$(sanitize_lower "$geo")"
			printf '%s\t%s\n' "$geosan" "$countries" >> "$GEO_TOKENS"
			for c in $countries; do
				echo "$c" >> "$NEEDED_CC"
			done
		fi

		if [ "$proto" = "all" ]; then
			emit_norm "$action" "$dir" tcp "$port" "$geosan"
			emit_norm "$action" "$dir" udp "$port" "$geosan"
		else
			emit_norm "$action" "$dir" "$proto" "$port" "$geosan"
		fi
	done < "$RULES_FILE"

	if [ ! -s "$RULES_NORM" ]; then
		echo "No rules defined in ${RULES_FILE}." >&2
		exit 1
	fi

	awk -F'\t' '!seen[$1]++' "$GEO_TOKENS" > "$GEO_FINAL"
}

zone_fresh() {
	f="$1"
	[ -s "$f" ] || return 1
	[ -z "$(find "$f" -mmin +"$((ZONE_CACHE_HOURS * 60))" 2>/dev/null)" ]
}

ensure_zones() {
	[ -s "$NEEDED_CC" ] || return 0
	sort -u "$NEEDED_CC" > "${TMP_DIR}/cc.uniq"

	while read -r cc; do
		[ -n "$cc" ] || continue
		v4="${ZONE_DIR}/${cc}.v4"
		v6="${ZONE_DIR}/${cc}.v6"
		if zone_fresh "$v4"; then
			continue
		fi

		t4="${TMP_DIR}/dl.v4"
		t6="${TMP_DIR}/dl.v6"
		: > "$t4"; : > "$t6"
		curl -fsSL "${IPDENY_V4_URL}/${cc}-aggregated.zone" -o "$t4" 2>/dev/null || true
		curl -fsSL "${IPDENY_V6_URL}/${cc}-aggregated.zone" -o "$t6" 2>/dev/null || true
		grep -E "$IPV4_RE" "$t4" > "${t4}.f" 2>/dev/null || true
		grep -Ei "$IPV6_RE" "$t6" > "${t6}.f" 2>/dev/null || true

		if [ -s "${t4}.f" ]; then
			install -m 0644 "${t4}.f" "$v4"
			install -m 0644 "${t6}.f" "$v6"
		elif [ -s "$v4" ]; then
			echo "Zone refresh failed for '${cc}', using cached copy." >&2
		else
			echo "Cannot download zone for country '${cc}' and no cache exists; aborting to avoid lockout." >&2
			exit 1
		fi
	done < "${TMP_DIR}/cc.uniq"
}

build_geo_sets() {
	while IFS="$TAB" read -r geosan countries; do
		[ -n "$geosan" ] || continue
		out4="${TMP_DIR}/g_${geosan}.v4"
		out6="${TMP_DIR}/g_${geosan}.v6"
		: > "$out4"; : > "$out6"
		for cc in $countries; do
			[ -f "${ZONE_DIR}/${cc}.v4" ] && cat "${ZONE_DIR}/${cc}.v4" >> "$out4"
			[ -f "${ZONE_DIR}/${cc}.v6" ] && cat "${ZONE_DIR}/${cc}.v6" >> "$out6"
		done
		sort -u "$out4" -o "$out4"
		sort -u "$out6" -o "$out6"
		if [ ! -s "$out4" ] && [ ! -s "$out6" ]; then
			echo "Geo group '${geosan}' produced no addresses; aborting." >&2
			exit 1
		fi
	done < "$GEO_FINAL"
}

fetch_abuseipdb() {
	: > "${TMP_DIR}/abuse4.set"
	: > "${TMP_DIR}/abuse6.set"

	if [ -z "${ABUSEIPDB_API_KEY:-}" ]; then
		echo "ABUSEIPDB_API_KEY is not set in ${CONFIG_FILE}; AbuseIPDB sets will be empty." >&2
		return 0
	fi

	if ! curl -fsS --get "$ABUSEIPDB_URL" \
		--data-urlencode "confidenceMinimum=${ABUSEIPDB_CONFIDENCE_MINIMUM}" \
		--data-urlencode "limit=${ABUSEIPDB_LIMIT}" \
		--data-urlencode "days=${ABUSEIPDB_DAYS}" \
		--data-urlencode "plaintext=true" \
		-H "Key: ${ABUSEIPDB_API_KEY}" \
		-H "Accept: text/plain" > "${TMP_DIR}/abuse.raw"; then
		echo "AbuseIPDB download failed; keeping AbuseIPDB sets empty for this run." >&2
		return 0
	fi

	sort -u "${TMP_DIR}/abuse.raw" | grep -E "$IPV4_RE" > "${TMP_DIR}/abuse4.set" || true
	sort -u "${TMP_DIR}/abuse.raw" | grep -Ei "$IPV6_RE" > "${TMP_DIR}/abuse6.set" || true
}

build_whitelist() {
	: > "${TMP_DIR}/wl4.raw"
	: > "${TMP_DIR}/wl6.raw"

	for entry in $WHITELIST; do
		case "$entry" in
			*:*) echo "$entry" >> "${TMP_DIR}/wl6.raw" ;;
			*)   echo "$entry" >> "${TMP_DIR}/wl4.raw" ;;
		esac
	done

	sort -u "${TMP_DIR}/wl4.raw" | grep -E "$IPV4_RE" > "${TMP_DIR}/whitelist4.set" || true
	sort -u "${TMP_DIR}/wl6.raw" | grep -Ei "$IPV6_RE" > "${TMP_DIR}/whitelist6.set" || true
}

write_set_elements() {
	file="$1"
	if [ -s "$file" ]; then
		awk 'BEGIN{first=1} { if (!first) printf ",\n"; first=0; printf "\t\t\t%s", $0 } END{ printf "\n" }' "$file"
	fi
}

write_addr_set() {
	name="$1"
	type="$2"
	file="$3"

	printf '\tset %s {\n\t\ttype %s\n\t\tflags interval\n' "$name" "$type"
	if [ -s "$file" ]; then
		printf '\t\telements = {\n'
		write_set_elements "$file"
		printf '\t\t}\n'
	fi
	printf '\t}\n\n'
}

emit_chain() {
	# $1 direction: in|out
	dir="$1"
	awk -v d="$dir" 'BEGIN{f=1} $2==d{f=0} END{exit f}' "$RULES_NORM" || return 0

	if [ "$dir" = "in" ]; then
		chain="input"; hook="input"; a4="ip saddr"; a6="ip6 saddr"
	else
		chain="output"; hook="output"; a4="ip daddr"; a6="ip6 daddr"
	fi

	printf '\tchain %s {\n' "$chain"
	printf '\t\ttype filter hook %s priority -100; policy accept;\n' "$hook"
	# Stateful: replies to connections you initiated are always allowed, so
	# inbound is permitted only as a response to a request unless an allow rule
	# opens the port for new connections.
	printf '\t\tct state established,related accept\n'

	# Whitelist always wins on every managed port (source for in, dest for out).
	[ -s "${TMP_DIR}/whitelist4.set" ] && printf '\t\t%s @whitelist4 accept\n' "$a4"
	[ -s "${TMP_DIR}/whitelist6.set" ] && printf '\t\t%s @whitelist6 accept\n' "$a6"

	# AbuseIPDB blacklist drop on every managed port.
	tcp_abuse="$(awk -v d="$dir" '$2==d && $3=="tcp"{print $4}' "$RULES_NORM" | sort -un | paste -sd, -)"
	udp_abuse="$(awk -v d="$dir" '$2==d && $3=="udp"{print $4}' "$RULES_NORM" | sort -un | paste -sd, -)"
	if [ -n "$tcp_abuse" ]; then
		printf '\t\ttcp dport { %s } %s @abuse4 drop\n' "$tcp_abuse" "$a4"
		printf '\t\ttcp dport { %s } %s @abuse6 drop\n' "$tcp_abuse" "$a6"
	fi
	if [ -n "$udp_abuse" ]; then
		printf '\t\tudp dport { %s } %s @abuse4 drop\n' "$udp_abuse" "$a4"
		printf '\t\tudp dport { %s } %s @abuse6 drop\n' "$udp_abuse" "$a6"
	fi

	# Explicit geo blocks, before the allows.
	awk -v d="$dir" '$1=="deny" && $2==d' "$RULES_NORM" | while read -r _a _d proto port geosan; do
		printf '\t\t%s dport %s %s @g_%s4 drop\n' "$proto" "$port" "$a4" "$geosan"
		printf '\t\t%s dport %s %s @g_%s6 drop\n' "$proto" "$port" "$a6" "$geosan"
	done

	# Geo allows.
	awk -v d="$dir" '$1=="allow" && $2==d' "$RULES_NORM" | while read -r _a _d proto port geosan; do
		if [ "$geosan" = "any" ]; then
			printf '\t\t%s dport %s accept\n' "$proto" "$port"
		else
			printf '\t\t%s dport %s %s @g_%s4 accept\n' "$proto" "$port" "$a4" "$geosan"
			printf '\t\t%s dport %s %s @g_%s6 accept\n' "$proto" "$port" "$a6" "$geosan"
		fi
	done

	# Deny-by-default for geo-fenced ports (an allow rule, geo != any).
	tcp_def="$(awk -v d="$dir" '$1=="allow" && $2==d && $3=="tcp" && $5!="any"{print $4}' "$RULES_NORM" | sort -un | paste -sd, -)"
	udp_def="$(awk -v d="$dir" '$1=="allow" && $2==d && $3=="udp" && $5!="any"{print $4}' "$RULES_NORM" | sort -un | paste -sd, -)"
	[ -n "$tcp_def" ] && printf '\t\ttcp dport { %s } drop\n' "$tcp_def"
	[ -n "$udp_def" ] && printf '\t\tudp dport { %s } drop\n' "$udp_def"

	printf '\t}\n'
}

generate() {
	{
		# Atomic replace: create the table if missing, delete it, then rebuild it
		# from scratch in a single nft -f load, so the rules are never absent.
		printf 'table %s %s\n' "$TABLE_FAMILY" "$TABLE_NAME"
		printf 'delete table %s %s\n' "$TABLE_FAMILY" "$TABLE_NAME"
		printf 'table %s %s {\n' "$TABLE_FAMILY" "$TABLE_NAME"

		write_addr_set "whitelist4" "ipv4_addr" "${TMP_DIR}/whitelist4.set"
		write_addr_set "whitelist6" "ipv6_addr" "${TMP_DIR}/whitelist6.set"
		write_addr_set "abuse4" "ipv4_addr" "${TMP_DIR}/abuse4.set"
		write_addr_set "abuse6" "ipv6_addr" "${TMP_DIR}/abuse6.set"
		while IFS="$TAB" read -r geosan _c; do
			[ -n "$geosan" ] || continue
			write_addr_set "g_${geosan}4" "ipv4_addr" "${TMP_DIR}/g_${geosan}.v4"
			write_addr_set "g_${geosan}6" "ipv6_addr" "${TMP_DIR}/g_${geosan}.v6"
		done < "$GEO_FINAL"

		emit_chain "in"
		emit_chain "out"

		printf '}\n'
	} > "${TMP_DIR}/abeiplinux.nft"
}

parse_rules
ensure_zones
build_geo_sets
fetch_abuseipdb
build_whitelist
generate

nft -c -f "${TMP_DIR}/abeiplinux.nft"
install -m 0644 "${TMP_DIR}/abeiplinux.nft" "$NFT_FILE"
nft -f "$NFT_FILE"

install -m 0644 "${TMP_DIR}/whitelist4.set" "${STATE_DIR}/whitelist4.set"
install -m 0644 "${TMP_DIR}/whitelist6.set" "${STATE_DIR}/whitelist6.set"
install -m 0644 "${TMP_DIR}/abuse4.set" "${STATE_DIR}/abuse4.set"
install -m 0644 "${TMP_DIR}/abuse6.set" "${STATE_DIR}/abuse6.set"

printf 'Loaded %s/%s: rules=%s geo_groups=%s whitelist4=%s whitelist6=%s abuse4=%s abuse6=%s\n' \
	"$TABLE_FAMILY" "$TABLE_NAME" \
	"$(wc -l < "$RULES_NORM")" \
	"$(wc -l < "$GEO_FINAL")" \
	"$(wc -l < "${TMP_DIR}/whitelist4.set")" \
	"$(wc -l < "${TMP_DIR}/whitelist6.set")" \
	"$(wc -l < "${TMP_DIR}/abuse4.set")" \
	"$(wc -l < "${TMP_DIR}/abuse6.set")"
