#!/bin/sh
# nftgeo - operator CLI for the nftgeo geo firewall.
# Read-only helpers plus dispatch to the update engine. See `nftgeo help`.
set -eu

FAM="${TABLE_FAMILY:-inet}"
TABLE="${TABLE_NAME:-nftgeo}"
DYN_TABLE="${DYN_TABLE:-nftgeo_dyn}"
STATE_DIR="${STATE_DIR:-/var/lib/nftgeo}"
NFT_FILE="${NFT_FILE:-/etc/nftables.d/nftgeo.nft}"
ABUSE_FEEDS_CACHE_DIR="${ABUSE_FEEDS_CACHE_DIR:-${STATE_DIR}/feeds}"
DYN_STATE="${DYN_STATE:-${STATE_DIR}/dynblock.tsv}"
GEN_DIR="${GEN_DIR:-${STATE_DIR}/generations}"
SENTINEL="${SENTINEL:-${STATE_DIR}/.pending-confirm}"
TAB="$(printf '\t')"

# IP validation patterns — shared with nftgeo-update
IPV4_RE='^([0-9]{1,3}\.){3}[0-9]{1,3}(/[0-9]{1,2})?$'
IPV6_RE='^[0-9a-fA-F:]+(/[0-9]{1,3})?$'

# Locate the update engine (for `apply` and `version`).
ENGINE="${NFTGEO_UPDATE:-}"
if [ -z "$ENGINE" ]; then
	for c in /usr/local/sbin/nftgeo-update "$(dirname -- "$0")/nftgeo-update"; do
		[ -x "$c" ] && ENGINE="$c" && break
	done
fi

usage() {
	cat <<EOF
Usage: nftgeo <command> [args]

  check <ip>     Show what the firewall does to an address (whitelist / abuse /
                 geo sets, the rules that match it, and the resulting verdict).
  status         One-screen summary: version, last run, set sizes, drop
                 counters, feed health, and the next scheduled run.
  validate       Render the ruleset from the current config and check it, without
                 loading it. Exits non-zero if the config is invalid. (root)
  plan           Show how the rendered ruleset differs from what is loaded, as a
                 policy diff (set contents elided). (root)
  migrate-sequential [--dry-run]   Add explicit catch-all 'deny ... any' rules so
                 a config written for the old model keeps closing geo-fenced ports
                 under sequential (file-order) evaluation. Writes a rules.d
                 drop-in; deploy with 'apply --confirm'. (root)
  block <ip> [ttl]   Drop an address now for ttl (default 1h; e.g. 30m, 2d),
                 without editing rules or a reload. Refuses a whitelisted or your
                 own SSH source unless --force. Survives updates. (root)
  unblock <ip>   Remove a dynamic block. (root)
  blocklist      List the current dynamic blocks and their remaining TTL.
  apply          Rebuild and load the ruleset now (runs the update engine).
  apply --confirm [T]  Apply, then auto-roll-back after T seconds (default 120)
                 unless you run 'nftgeo apply --commit' - a deadman against a
                 change that locks you out. (root)
  apply --commit / confirm   Keep a --confirm apply (cancel the rollback). (root)
  rollback       Restore the previous ruleset generation. (root)
  version        Print the nftgeo version.
  help           Show this help.
EOF
}

need_table() {
	nft list table "$FAM" "$TABLE" >/dev/null 2>&1 && return 0
	echo "nftgeo table ${FAM} ${TABLE} is not loaded (try: systemctl start nftgeo.service)" >&2
	return 1
}

# True if $ip is contained in set $1.
in_set() { nft get element "$FAM" "$TABLE" "$1" "{ $ip }" >/dev/null 2>&1; }

cmd_check() {
	ip="${1:-}"
	[ -n "$ip" ] || { echo "usage: nftgeo check <ip>" >&2; exit 2; }
	need_table || exit 1
	case "$ip" in *:*) fam=6 ;; *) fam=4 ;; esac
	echo "${ip}  (IPv${fam})"

	if in_set "whitelist${fam}"; then wl=YES; else wl=no; fi
	if in_set "abuse${fam}"; then ab=YES; else ab=no; fi
	printf '  whitelist : %s\n' "$wl"
	printf '  abuse     : %s\n' "$ab"

	# Which geo/group sets contain it. Testing a wrong-family set simply fails.
	matched=""
	for s in $(nft list table "$FAM" "$TABLE" 2>/dev/null \
			| grep -oE 'set g_[A-Za-z0-9_]+ ' | awk '{print $2}'); do
		in_set "$s" && matched="${matched} ${s}"
	done
	printf '  geo sets  :%s\n' "${matched:- (none)}"

	# Only rules for sets the address actually belongs to.
	hit="$matched"
	[ "$wl" = YES ] && hit="${hit} whitelist${fam}"
	[ "$ab" = YES ] && hit="${hit} abuse${fam}"
	echo "  matching rules:"
	rules="$(for ch in input output forward; do
		for s in ${hit}; do
			nft list chain "$FAM" "$TABLE" "$ch" 2>/dev/null | grep -E "@${s} " \
				| sed "s/^[[:space:]]*/    ${ch}  /"
		done
	done | sort -u)"
	if [ -n "$rules" ]; then printf '%s\n' "$rules"; else echo "    (none)"; fi

	if [ "$wl" = YES ]; then
		echo "verdict: ALLOWED - whitelisted, bypasses geo and abuse"
	elif [ "$ab" = YES ]; then
		echo "verdict: DROPPED where a 'deny ... abuse' rule applies (unless also whitelisted)"
	elif [ -n "$matched" ]; then
		echo "verdict: allowed on the ports shown above; other managed ports fall to deny-by-default"
	else
		echo "verdict: in no managed set - reaches whatever your rules leave open (unmanaged ports untouched)"
	fi
}

set_count() {
	# Element count of set $1, or "-" if absent. Counts comma/newline separated
	# elements without choking on interval ranges.
	nft list set "$FAM" "$TABLE" "$1" 2>/dev/null | awk '
		/elements = \{/ { cap=1; sub(/.*elements = \{/, "") }
		cap {
			line=$0; sub(/\}.*/, "", line); gsub(/[ \t]/, "", line); body=body line
			if ($0 ~ /\}/) { if (body=="") print 0; else print gsub(/,/,",",body)+1; exit }
		}
		END { if (!cap) print 0 }
	'
}

cmd_status() {
	v="$("$ENGINE" --version 2>/dev/null | awk '{print $NF}')"
	echo "nftgeo ${v:-?}   table ${FAM} ${TABLE}"
	if ! nft list table "$FAM" "$TABLE" >/dev/null 2>&1; then
		echo "table: NOT LOADED (try: systemctl start nftgeo.service)"
		return 0
	fi

	last="$(journalctl -u nftgeo.service --no-pager -o cat 2>/dev/null \
		| grep -iE "loaded ${FAM}/${TABLE}" | tail -1)"
	[ -n "$last" ] && echo "last run : ${last}"

	chains="$(nft list table "$FAM" "$TABLE" | grep -oE 'chain (input|output|forward)' \
		| awk '{print $2}' | paste -sd, -)"
	echo "chains   : ${chains:-none}"
	printf 'sets     : whitelist4=%s whitelist6=%s abuse4=%s abuse6=%s\n' \
		"$(set_count whitelist4)" "$(set_count whitelist6)" \
		"$(set_count abuse4)" "$(set_count abuse6)"

	echo "drop rules (live counters):"
	for ch in input output forward; do
		nft list chain "$FAM" "$TABLE" "$ch" 2>/dev/null | grep -E 'counter.*drop' \
			| sed "s/^[[:space:]]*/  ${ch}  /"
	done

	if [ -d "$ABUSE_FEEDS_CACHE_DIR" ] && [ -n "$(ls -A "$ABUSE_FEEDS_CACHE_DIR" 2>/dev/null)" ]; then
		echo "abuse feeds (cache mtime):"
		for f in "$ABUSE_FEEDS_CACHE_DIR"/*; do
			[ -f "$f" ] || continue
			echo "  $(date -r "$f" '+%Y-%m-%d %H:%M')  $(basename "$f")"
		done
	fi

	t="$(systemctl list-timers nftgeo.timer --no-pager 2>/dev/null | sed -n '2p')"
	[ -n "$t" ] && echo "next run : $(echo "$t" | sed 's/^[[:space:]]*//')"
	return 0
}

cmd_validate() {
	[ -n "$ENGINE" ] || { echo "nftgeo-update not found" >&2; exit 1; }
	if out="$(RENDER_ONLY=1 "$ENGINE" 2>&1)"; then
		echo "OK: ${out}"
	else
		echo "INVALID:" >&2
		echo "$out" >&2
		exit 1
	fi
}

# Drop set element bodies so a policy diff isn't buried under thousands of
# changing abuse/geo addresses (and so an elided empty set matches a populated
# one - only the rules and set definitions are compared).
strip_elements() {
	awk '
		/elements = \{/ { if (/\}/) next; inblk=1; next }
		inblk && /\}/   { inblk=0; next }
		inblk           { next }
		                { print }
	' "$1"
}

cmd_plan() {
	[ -n "$ENGINE" ] || { echo "nftgeo-update not found" >&2; exit 1; }
	rendered="$(mktemp)"; err="$(mktemp)"
	if ! RENDER_ONLY=1 RENDER_OUT="$rendered" "$ENGINE" >/dev/null 2>"$err"; then
		echo "render failed:" >&2; cat "$err" >&2; rm -f "$rendered" "$err"; exit 1
	fi
	rm -f "$err"
	if [ ! -f "$NFT_FILE" ]; then
		echo "no current ruleset at ${NFT_FILE}; this would be the first load."
		rm -f "$rendered"; return 0
	fi
	a="$(mktemp)"; b="$(mktemp)"
	strip_elements "$NFT_FILE" > "$a"
	strip_elements "$rendered" > "$b"
	d="$(diff -u "$a" "$b" || true)"
	rm -f "$a" "$b" "$rendered"
	if [ -z "$d" ]; then
		echo "no policy changes (set contents such as abuse/geo addresses may still differ)."
	else
		echo "policy changes (loaded -> rendered; set contents elided):"
		echo "$d"
	fi
}

dur_to_sec() {
	# 30m | 1h | 2d | 3600s | bare seconds -> seconds; empty on invalid.
	case "$1" in
		*d) n=${1%d}; case "$n" in *[!0-9]*|'') echo ""; return;; esac; echo $((n*86400)) ;;
		*h) n=${1%h}; case "$n" in *[!0-9]*|'') echo ""; return;; esac; echo $((n*3600)) ;;
		*m) n=${1%m}; case "$n" in *[!0-9]*|'') echo ""; return;; esac; echo $((n*60)) ;;
		*s) n=${1%s}; case "$n" in *[!0-9]*|'') echo ""; return;; esac; echo "$n" ;;
		*[!0-9]*|'') echo "" ;;
		*) echo "$1" ;;
	esac
}

ensure_dyn() {
	# Dynamic manual-block table, separate from the geo table so nftgeo-update
	# never rebuilds it - blocks survive a ruleset reload. Runs before the geo
	# table (priority -150); the block/unblock commands guard against self-lockout.
	nft list table "$FAM" "$DYN_TABLE" >/dev/null 2>&1 && return 0
	nft -f - <<EOF
table $FAM $DYN_TABLE {
	set dynblock4 { type ipv4_addr; flags timeout; }
	set dynblock6 { type ipv6_addr; flags timeout; }
	chain input {
		type filter hook input priority -150; policy accept;
		ip saddr @dynblock4 counter drop
		ip6 saddr @dynblock6 counter drop
	}
	chain output {
		type filter hook output priority -150; policy accept;
		ip daddr @dynblock4 counter drop
		ip6 daddr @dynblock6 counter drop
	}
}
EOF
}

cmd_block() {
	force=0; [ "${1:-}" = "--force" ] && { force=1; shift; }
	ip="${1:-}"; ttl="${2:-1h}"
	[ -n "$ip" ] || { echo "usage: nftgeo block [--force] <ip> [ttl]   (ttl e.g. 30m, 1h, 2d)" >&2; exit 2; }
	case "$ip" in
		*:*) fam=6; printf '%s' "$ip" | grep -Eiq "$IPV6_RE" || { echo "invalid IPv6: ${ip}" >&2; exit 2; } ;;
		*)   fam=4; printf '%s' "$ip" | grep -Eq "$IPV4_RE" || { echo "invalid IPv4: ${ip}" >&2; exit 2; } ;;
	esac
	sec="$(dur_to_sec "$ttl")"
	{ [ -n "$sec" ] && [ "$sec" -gt 0 ]; } || { echo "bad ttl '${ttl}' (use 30m, 1h, 2d, or seconds)" >&2; exit 2; }
	if [ "$force" != 1 ]; then
		if nft get element "$FAM" "$TABLE" "whitelist${fam}" "{ $ip }" >/dev/null 2>&1; then
			echo "refusing: ${ip} is whitelisted; use --force to block anyway" >&2; exit 1
		fi
		src="${SSH_CLIENT:-}"; src="${src%% *}"
		[ -n "$src" ] && [ "$ip" = "$src" ] && { echo "refusing: ${ip} is your current SSH source; use --force" >&2; exit 1; }
	fi
	ensure_dyn
	nft add element "$FAM" "$DYN_TABLE" "dynblock${fam}" "{ $ip timeout ${sec}s }"
	now="$(date +%s)"; exp="$((now + sec))"
	mkdir -p "$STATE_DIR"; touch "$DYN_STATE"
	awk -F"$TAB" -v ip="$ip" '$1!=ip' "$DYN_STATE" > "${DYN_STATE}.n" 2>/dev/null || true
	mv "${DYN_STATE}.n" "$DYN_STATE"
	printf '%s\t%s\t%s\n' "$ip" "$fam" "$exp" >> "$DYN_STATE"
	echo "blocked ${ip} for ${ttl} (until $(date -d "@${exp}" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo "@${exp}"))"
}

cmd_unblock() {
	ip="${1:-}"; [ -n "$ip" ] || { echo "usage: nftgeo unblock <ip>" >&2; exit 2; }
	case "$ip" in
		*:*) fam=6; printf '%s' "$ip" | grep -Eiq "$IPV6_RE" || { echo "invalid IPv6: ${ip}" >&2; exit 2; } ;;
		*)   fam=4; printf '%s' "$ip" | grep -Eq "$IPV4_RE" || { echo "invalid IPv4: ${ip}" >&2; exit 2; } ;;
	esac
	nft delete element "$FAM" "$DYN_TABLE" "dynblock${fam}" "{ $ip }" 2>/dev/null || true
	if [ -f "$DYN_STATE" ]; then
		awk -F"$TAB" -v ip="$ip" '$1!=ip' "$DYN_STATE" > "${DYN_STATE}.n" 2>/dev/null || true
		mv "${DYN_STATE}.n" "$DYN_STATE"
	fi
	echo "unblocked ${ip}"
}

cmd_blocklist() {
	if ! nft list table "$FAM" "$DYN_TABLE" >/dev/null 2>&1; then
		echo "no dynamic blocks (table ${FAM} ${DYN_TABLE} not present)"; return 0
	fi
	echo "dynamic blocks (in-kernel, auto-expiring):"
	found=0
	for s in dynblock4 dynblock6; do
		el="$(nft list set "$FAM" "$DYN_TABLE" "$s" 2>/dev/null | tr '\n' ' ' \
			| sed -n 's/.*elements = {\([^}]*\)}.*/\1/p')"
		[ -n "$el" ] || continue
		printf '%s' "$el" | tr ',' '\n' \
			| sed 's/^[[:space:]]*/  /; s/[[:space:]]*$//' | grep -v '^[[:space:]]*$' && found=1
	done
	[ "$found" = 1 ] || echo "  (none)"
}

cmd_restore_dyn() {
	# Re-create the dynamic block table from persisted state after a reboot,
	# dropping entries whose TTL has passed. Idempotent; wired to run after each
	# engine start (incl. boot) via the service.
	#
	# Also clean up a stale sentinel from an interrupted "apply --confirm":
	# the nohup'd deadman process dies on reboot, but the sentinel file persists
	# and would block future applies until manually removed.
	rm -f "$SENTINEL" 2>/dev/null || true
	[ -s "$DYN_STATE" ] || return 0
	ensure_dyn
	now="$(date +%s)"
	: > "${DYN_STATE}.n"
	while IFS="$TAB" read -r ip fam exp; do
		[ -n "$ip" ] || continue
		case "$exp" in ''|*[!0-9]*) continue ;; esac
		rem=$((exp - now)); [ "$rem" -gt 0 ] || continue
		nft add element "$FAM" "$DYN_TABLE" "dynblock${fam}" "{ $ip timeout ${rem}s }" 2>/dev/null || true
		printf '%s\t%s\t%s\n' "$ip" "$fam" "$exp" >> "${DYN_STATE}.n"
	done < "$DYN_STATE"
	mv "${DYN_STATE}.n" "$DYN_STATE"
}

snapshot_current() {
	# Save the currently loaded ruleset (the installed NFT_FILE, or a delete-table
	# stub if there is none yet) as a generation, point `previous` at it, keep the
	# last 10. Echoes the snapshot path.
	mkdir -p "$GEN_DIR"
	snap="${GEN_DIR}/$(date +%s).nft"
	if [ -f "$NFT_FILE" ]; then
		cp "$NFT_FILE" "$snap"
	else
		printf 'table %s %s\ndelete table %s %s\n' "$FAM" "$TABLE" "$FAM" "$TABLE" > "$snap"
	fi
	echo "$snap" > "${GEN_DIR}/previous"
	ls -1t "$GEN_DIR"/*.nft 2>/dev/null | tail -n +11 | while read -r f; do rm -f "$f"; done
	echo "$snap"
}

kill_deadman() {
	# Remove the sentinel first - the deadman polls it and self-exits within ~1s -
	# then best-effort kill the waiter for immediacy.
	pid="$(cat "$SENTINEL" 2>/dev/null || true)"
	rm -f "$SENTINEL"
	[ -n "$pid" ] || return 0
	# Verify the PID is still our deadman (not a recycled PID after reboot):
	# check /proc for the sentinel path in the process cmdline.
	if [ -r "/proc/${pid}/cmdline" ] 2>/dev/null; then
		tr '\0' ' ' < "/proc/${pid}/cmdline" 2>/dev/null | grep -q "${SENTINEL}" && kill "$pid" 2>/dev/null || true
	else
		kill "$pid" 2>/dev/null || true
	fi
}

cmd_confirm() {
	[ -f "$SENTINEL" ] || { echo "nothing to confirm"; return 0; }
	kill_deadman
	echo "confirmed; the change is kept."
}

cmd_rollback() {
	prev="$(cat "${GEN_DIR}/previous" 2>/dev/null || true)"
	{ [ -n "$prev" ] && [ -f "$prev" ]; } || { echo "no previous generation to roll back to" >&2; exit 1; }
	nft -f "$prev"
	cp "$prev" "$NFT_FILE" 2>/dev/null || true
	[ -f "$SENTINEL" ] && kill_deadman
	echo "rolled back to ${prev}"
}

cmd_apply() {
	case "${1:-}" in
		--commit)
			cmd_confirm ;;
		--confirm)
			shift; T="${1:-120}"
			case "$T" in ''|*[!0-9]*) echo "bad confirm timeout '${T}' (seconds)" >&2; exit 2 ;; esac
			[ -n "$ENGINE" ] || { echo "nftgeo-update not found" >&2; exit 1; }
			[ -f "$SENTINEL" ] && { echo "a confirm is already pending; run 'nftgeo apply --commit' or 'nftgeo rollback' first" >&2; exit 1; }
			snap="$(snapshot_current)"
			"$ENGINE"
			# Detached deadman: rolls back to the snapshot unless the sentinel is
			# removed (by --commit) within T seconds. It polls the sentinel once a
			# second, so removing it makes the deadman self-exit within ~1s with no
			# long-lived sleep to reap. nohup so it survives this process exiting.
			dm="i=0; while [ \$i -lt ${T} ]; do [ -f '${SENTINEL}' ] || exit 0; sleep 1; i=\$((i+1)); done; [ -f '${SENTINEL}' ] && { nft -f '${snap}' 2>/dev/null; cp '${snap}' '${NFT_FILE}' 2>/dev/null; logger -t nftgeo 'deadman: apply not confirmed in ${T}s, rolled back' 2>/dev/null; rm -f '${SENTINEL}'; }"
			nohup sh -c "$dm" >/dev/null 2>&1 &
			echo "$!" > "$SENTINEL"
			echo "Applied with a ${T}s deadman. If you still have access, keep it with:"
			echo "    nftgeo apply --commit"
			echo "Otherwise it auto-rolls-back to the previous ruleset in ${T}s." ;;
		"")
			[ -n "$ENGINE" ] || { echo "nftgeo-update not found" >&2; exit 1; }
			exec "$ENGINE" ;;
		*)
			echo "usage: nftgeo apply [--confirm [seconds] | --commit]" >&2; exit 2 ;;
	esac
}

# Migrate a config written for the old declarative model (all deny before all
# allow + automatic per-port deny-by-default) to the sequential model: for every
# geo-restricted "allow <dir> <proto> <port> <target>" that has no catch-all
# "deny <dir> <proto> <port> any", generate that deny so the port stays closed to
# other sources exactly as before. Output goes to a sorted-last rules.d drop-in
# so it runs after your allows. Idempotent. Pass --dry-run to preview.
cmd_migrate_sequential() {
	_dry=0
	[ "${1:-}" = "--dry-run" ] && _dry=1
	RULES_FILE="${RULES_FILE:-/etc/nftgeo/rules.conf}"
	RULES_DIR="${RULES_DIR:-/etc/nftgeo/rules.d}"
	_mig="${RULES_DIR}/zz-sequential-migration.conf"

	_tmp="$(mktemp)"
	for _f in "$RULES_FILE" "$RULES_DIR"/*.conf; do
		[ -f "$_f" ] || continue
		[ "$_f" = "$_mig" ] && continue
		cat "$_f" >> "$_tmp"
	done

	# Group by "<dir> <proto> <port>": a geo-restricted allow needs a catch-all
	# deny unless one already exists. Skip zone rules and non-allow/deny lines.
	_needed="$(awk '
		{ sub(/#.*/, "") }
		$1!="allow" && $1!="deny" { next }
		$2!="in" && $2!="out" && $2!="fwd-in" && $2!="fwd-out" { next }
		# Only port-bearing protocols with an actual port get a catch-all deny;
		# skip malformed/portless rules the engine itself would not turn into a
		# per-port drop (so a stray "allow in any FOO bar" is left alone).
		($3=="tcp" || $3=="udp" || $3=="sctp" || $3=="all") && $4!="-" && $4!="" {
			if ($1=="allow" && $5!="any" && $5!="") need[$2" "$3" "$4]=1
			if ($1=="deny"  && $5=="any")           have[$2" "$3" "$4]=1
		}
		END { for (k in need) if (!(k in have)) print k }
	' "$_tmp" | sort)"
	rm -f "$_tmp"

	if [ -z "$_needed" ]; then
		echo "Nothing to migrate: every geo-restricted 'allow' already has a catch-all 'deny ... any' (or none exist)."
		if [ -f "$_mig" ] && [ "$_dry" = 0 ]; then
			echo "Removing now-empty ${_mig}"
			rm -f "$_mig"
		fi
		return 0
	fi

	_body=""
	_n=0
	while IFS=' ' read -r _d _p _pt; do
		[ -n "$_d" ] || continue
		_body="${_body}deny ${_d} ${_p} ${_pt} any # sequential-migration: close ${_p}/${_pt} to sources not explicitly allowed
"
		_n=$((_n + 1))
	done <<EOF
$_needed
EOF

	echo "Adds ${_n} catch-all deny rule(s) to preserve the pre-1.57 (deny-by-default) behaviour:"
	printf '%s' "$_body" | sed 's/^/  /'
	if [ "$_dry" = 1 ]; then
		echo "(dry run — nothing written)"
		return 0
	fi
	mkdir -p "$RULES_DIR"
	{
		echo "# Generated by 'nftgeo migrate-sequential'. Reproduces the pre-1.57 per-port"
		echo "# deny-by-default under the sequential (file-order) model. Runs after your"
		echo "# allows. Delete a line to intentionally leave a port open; regenerate with"
		echo "# 'nftgeo migrate-sequential'."
		printf '%s' "$_body"
	} > "$_mig"
	echo ""
	echo "Wrote ${_mig}. Review, then deploy behind the deadman:"
	echo "    nftgeo validate && nftgeo apply --confirm"
	echo "    # ...confirm you still have access..."
	echo "    nftgeo apply --commit"
}

cmd="${1:-help}"
[ $# -gt 0 ] && shift || true
case "$cmd" in
	migrate-sequential) cmd_migrate_sequential "$@" ;;
	check)             cmd_check "$@" ;;
	status)            cmd_status ;;
	validate)          cmd_validate ;;
	plan)              cmd_plan ;;
	block)             cmd_block "$@" ;;
	unblock)           cmd_unblock "$@" ;;
	blocklist)         cmd_blocklist ;;
	restore-dyn)       cmd_restore_dyn ;;
	apply)             cmd_apply "$@" ;;
	confirm)           cmd_confirm ;;
	rollback)          cmd_rollback ;;
	version|--version|-V) [ -n "$ENGINE" ] && exec "$ENGINE" --version || { echo "nftgeo (engine not found)"; exit 1; } ;;
	help|-h|--help)    usage ;;
	*)                 echo "unknown command: ${cmd}" >&2; usage >&2; exit 2 ;;
esac
