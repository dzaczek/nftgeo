#!/bin/sh
set -eu

NFTGEO_VERSION="1.73.0~beta.7"

# Built-in well-known services usable in the port field by name (e.g. "https").
# Bare port lists (no /proto), so a name takes the rule's proto: "allow in udp dns"
# -> 53/udp, "allow in tcp dns" -> 53/tcp. A user SERVICE_<NAME> overrides a name.
# Kept in sync with the dashboard's port/service autocomplete via "--services".
BUILTIN_SERVICES="ssh:22 sftp:22 http:80 https:443 http-alt:8080 https-alt:8443 web:80,443 dns:53 dot:853 ntp:123 smtp:25 smtps:465 submission:587 imap:143 imaps:993 pop3:110 pop3s:995 ftp:21 telnet:23 rdp:3389 vnc:5900 mysql:3306 postgres:5432 redis:6379 mongodb:27017 memcached:11211 ldap:389 ldaps:636 snmp:161 syslog:514 rsync:873 nfs:2049 smb:445 sip:5060 sips:5061 wireguard:51820 openvpn:1194 tftp:69 kerberos:88 grafana:3000 prometheus:9090 node-exporter:9100 alertmanager:9093 elasticsearch:9200 kibana:5601 rabbitmq:5672 kafka:9092 etcd:2379 consul:8500 minio:9000"

case "${1:-}" in
	--version|-V) echo "nftgeo-update ${NFTGEO_VERSION}"; exit 0 ;;
	--services)
		for _bs in $BUILTIN_SERVICES; do printf '%s %s\n' "${_bs%%:*}" "${_bs#*:}"; done
		exit 0 ;;
esac

CONFIG_FILE="${CONFIG_FILE:-/etc/nftgeo/config}"
RULES_FILE="${RULES_FILE:-/etc/nftgeo/rules.conf}"
RULES_DIR="${RULES_DIR:-/etc/nftgeo/rules.d}"
# Ingress hook (stateless, pre-routing early drop). Source-based accept/drop.
# The ingress hook is per-device, so it needs the interface(s) to attach to;
# INGRESS_DEV is a space- or comma-separated list (default: the default-route interface).
INGRESS_FILE="${INGRESS_FILE:-/etc/nftgeo/ingress.conf}"
INGRESS_DIR="${INGRESS_DIR:-/etc/nftgeo/ingress.d}"
INGRESS_DEV="${INGRESS_DEV:-}"
GROUPS_DIR="${GROUPS_DIR:-/etc/nftgeo/groups.d}"
STATE_DIR="${STATE_DIR:-/var/lib/nftgeo}"
ZONE_DIR="${ZONE_DIR:-${STATE_DIR}/zones}"
NFT_FILE="${NFT_FILE:-/etc/nftables.d/nftgeo.nft}"
TABLE_FAMILY="${TABLE_FAMILY:-inet}"
TABLE_NAME="${TABLE_NAME:-nftgeo}"
WHITELIST="${WHITELIST:-}"
WHITELIST_HOSTS="${WHITELIST_HOSTS:-}"
WHITELIST_FILE="${WHITELIST_FILE:-/etc/nftgeo/whitelist.conf}"
WHITELIST_HOSTS_FILE="${WHITELIST_HOSTS_FILE:-/etc/nftgeo/whitelist-hosts.conf}"
WHITELIST_HOSTS_RETENTION_DAYS="${WHITELIST_HOSTS_RETENTION_DAYS:-7}"
# Resolvers tried, in order, for WHITELIST_HOSTS. "local" = system resolver
# (getent); an IP = query that DNS server directly (needs dig/host/nslookup).
RESOLVERS="${RESOLVERS:-local}"
RESOLVE_TIMEOUT="${RESOLVE_TIMEOUT:-5}"
WHITELIST_HOSTS_STATE_FILE="${WHITELIST_HOSTS_STATE_FILE:-${STATE_DIR}/whitelist_hosts.tsv}"
ZONE_CACHE_HOURS="${ZONE_CACHE_HOURS:-20}"
# Optional: log dropped packets (rate-limited) to the kernel log / journald.
LOG_DROPS="${LOG_DROPS:-}"
# Optional: log whitelist hits (rate-limited) as "nftgeo-accept:whitelist", so you
# can see which whitelisted sources actually connect. Independent of LOG_DROPS.
LOG_WHITELIST="${LOG_WHITELIST:-}"
LOG_PREFIX="${LOG_PREFIX:-nftgeo-drop }"
LOG_LIMIT="${LOG_LIMIT:-limit rate 10/second}"
# The drop reason (abuse|geo|deny|default-deny) is appended as ":<reason>" to the
# log prefix, so the dashboard can show which policy dropped a packet.
LOG_PREFIX_BASE="$(printf '%s' "$LOG_PREFIX" | sed 's/[[:space:]]*$//')"
# NFLOG: deliver every "log prefix" packet to this nfnetlink_log multicast group
# instead of only the kernel ring buffer. The dashboard's built-in listener reads
# it, so drop stats/map work even in LXC/OpenVZ containers where the kernel log is
# the host's and unreadable from inside. 0 disables NFLOG (kernel log only, the
# pre-1.69 behaviour). Appended as " group N" after each log prefix.
NFLOG_GROUP="${NFLOG_GROUP:-5}"

# Default ban duration for "throttle" rules: a source that exceeds the rate is
# added to a dynamic block set for this long. Per-rule override with "ban <dur>".
THROTTLE_BAN="${THROTTLE_BAN:-1h}"

# Optional baseline hardening on every managed chain: accept loopback, drop
# invalid conntrack state, and always permit the ICMPv6 types IPv6 needs to work.
HARDEN="${HARDEN:-}"
ANTISPOOF="${ANTISPOOF:-}"
ICMPV6_ESSENTIAL="${ICMPV6_ESSENTIAL:-nd-router-solicit, nd-router-advert, nd-neighbor-solicit, nd-neighbor-advert, echo-request, echo-reply, packet-too-big, destination-unreachable, time-exceeded, parameter-problem}"
# With HARDEN, rate-limit inbound ping (ICMP/ICMPv6 echo-request) so a flood
# can't drown the host; excess is dropped, normal pings still answered. NDP and
# other essential ICMPv6 are never rate-limited. Set ICMP_RATE="0" to disable.
ICMP_RATE="${ICMP_RATE:-1/second}"
ICMP_BURST="${ICMP_BURST:-5}"

# Input chain default policy: "accept" (selective blocklist, the default) or
# "drop" (default-deny - only established/related, loopback, whitelist and your
# explicit "allow in" rules get in; everything else is dropped). Loopback is
# auto-accepted under drop even without HARDEN. Deploy behind the deadman.
DEFAULT_INPUT="${DEFAULT_INPUT:-accept}"

# Output/forward chain default policy: "accept" (default) or "drop" (default-deny).
# With "drop", only established/related, loopback, essential ICMPv6, and your
# explicit "allow out"/"allow fwd-*" rules pass — a strict-egress / strict-routing
# posture. DANGER: DEFAULT_OUTPUT="drop" blocks new outbound (DNS, package/zone
# updates, AbuseIPDB) unless you allow it; deploy behind the deadman.
DEFAULT_OUTPUT="${DEFAULT_OUTPUT:-accept}"
DEFAULT_FORWARD="${DEFAULT_FORWARD:-accept}"

# Inter-zone forwarding default (roadmap P5). "" (default) leaves forwarding
# between zones wide open except where a zone rule denies it; "deny" drops all
# forwarded traffic between zone interfaces that no zone rule explicitly allows.
SEGMENT_DEFAULT="${SEGMENT_DEFAULT:-}"

ABUSEIPDB_API_KEY="${ABUSEIPDB_API_KEY:-}"
ABUSEIPDB_CONFIDENCE_MINIMUM="${ABUSEIPDB_CONFIDENCE_MINIMUM:-90}"
ABUSEIPDB_LIMIT="${ABUSEIPDB_LIMIT:-10000}"
ABUSEIPDB_DAYS="${ABUSEIPDB_DAYS:-30}"
ABUSEIPDB_RETENTION_DAYS="${ABUSEIPDB_RETENTION_DAYS:-${ABUSEIPDB_DAYS}}"
ABUSEIPDB_URL="${ABUSEIPDB_URL:-https://api.abuseipdb.com/api/v2/blacklist}"
ABUSEIPDB_STATE_FILE="${ABUSEIPDB_STATE_FILE:-${STATE_DIR}/abuseipdb.tsv}"

# Extra plaintext IP/CIDR blocklists merged into the same "abuse" sets. Space- or
# newline-separated URLs. Only fetched when a rule targets "abuse".
ABUSE_FEEDS="${ABUSE_FEEDS:-}"
ABUSE_FEEDS_CACHE_DIR="${ABUSE_FEEDS_CACHE_DIR:-${STATE_DIR}/feeds}"
# Max entries kept from a single abuse feed. A runaway feed (millions of IPs)
# builds a huge nftables set that is slow to load and to query; cap it to what
# the box can comfortably handle. 0 disables the cap.
ABUSE_FEEDS_MAX="${ABUSE_FEEDS_MAX:-200000}"
# Aggregate the abuse addresses into CIDR ranges before loading (needs 'iprange';
# falls back to nft's own auto-merge if it is not installed). Shrinks big lists.
ABUSE_FEEDS_AGGREGATE="${ABUSE_FEEDS_AGGREGATE:-1}"
# Load the abuse set in batches of this many elements, pausing between each, so a
# very large set doesn't spike the box on load. 0 = load atomically (default).
ABUSE_FEEDS_BATCH="${ABUSE_FEEDS_BATCH:-0}"
ABUSE_FEEDS_BATCH_SLEEP="${ABUSE_FEEDS_BATCH_SLEEP:-1}"
ABUSE_LOAD_PROGRESS="${ABUSE_LOAD_PROGRESS:-${STATE_DIR}/abuse-load.progress}"
# Status file written after each run: abuse API key state, fetch timestamps,
# warnings. Read by the dashboard to show data freshness and config gaps.
STATUS_FILE="${STATUS_FILE:-${STATE_DIR}/status.json}"
GEO_FETCH_TS="${GEO_FETCH_TS:-${STATE_DIR}/geo_last_fetch}"
ABUSE_FETCH_TS="${ABUSE_FETCH_TS:-${STATE_DIR}/abuse_last_fetch}"

IPDENY_V4_URL="${IPDENY_V4_URL:-https://www.ipdeny.com/ipblocks/data/aggregated}"
IPDENY_V6_URL="${IPDENY_V6_URL:-https://www.ipdeny.com/ipv6/ipaddresses/aggregated}"

# Default region macros. Referenced by name in rules.conf. Override or add your
# own REGION_<NAME> variables in the config file.
REGION_EUROPE="${REGION_EUROPE:-ad al am at ax az ba be bg by ch cy cz de dk ee es fi fo fr gb ge gg gi gr hr hu ie im is it je li lt lu lv mc md me mk mt nl no pl pt ro rs ru se si sk sm tr ua va}"
REGION_NORTH_AMERICA="${REGION_NORTH_AMERICA:-us ca mx bz cr gt hn ni pa sv}"
REGION_CARIBBEAN="${REGION_CARIBBEAN:-ag ai aw bb bs bl bm bq cu cw dm do gd gp ht jm kn ky lc mf mq ms pr sx tc tt vc vg vi}"
REGION_SOUTH_AMERICA="${REGION_SOUTH_AMERICA:-ar bo br cl co ec fk gf gy pe py sr uy ve}"
REGION_MIDDLE_EAST="${REGION_MIDDLE_EAST:-ae bh il iq ir jo kw lb om ps qa sa sy tr ye}"
REGION_ASIA="${REGION_ASIA:-af bd bn bt cn id in jp kg kh kp kr kz la lk mm mn mv my np ph pk sg th tj tl tm tw uz vn}"
REGION_AFRICA="${REGION_AFRICA:-ao bf bi bj bw cd cf cg ci cm cv dj dz eg eh er et ga gh gm gn gq gw ke km lr ls ly ma mg ml mr mu mw mz na ne ng rw sc sd sl sn so ss st sz td tg tn tz ug za zm zw}"
REGION_OCEANIA="${REGION_OCEANIA:-au fj fm ki mh nc nr nz pf pg pw sb to tv vu ws}"

TMP_DIR="$(mktemp -d)"
cleanup() {
	rm -rf "$TMP_DIR"
}
trap cleanup EXIT
# Collects warning messages emitted during this run (one per line) for status.json.
WARN_FILE="${TMP_DIR}/warnings.txt"
: > "$WARN_FILE"
# Run an nft command, retrying a transient netlink EMSGSIZE ("Message too
# long"). In constrained containers (e.g. LXC on shared hosts like mikr.us) the
# netlink socket buffer can momentarily be too small for the atomic transaction,
# and net.core.wmem_max is host-controlled — often not raisable from inside. A
# real ruleset error is surfaced immediately, never retried.
nft_try() {
	_attempt=1
	while :; do
		if _nfterr="$(nft "$@" 2>&1 >/dev/null)"; then
			[ -n "$_nfterr" ] && printf '%s\n' "$_nfterr" >&2
			return 0
		fi
		case "$_nfterr" in
		*"Message too long"*)
			if [ "$_attempt" -ge 5 ]; then
				printf '%s\n' "$_nfterr" >&2
				echo "nft still reports 'Message too long' after ${_attempt} attempts; the host's net.core.wmem_max is too small for this container's ruleset." >&2
				return 1
			fi
			_attempt=$((_attempt + 1))
			sleep 1
			;;
		*)
			printf '%s\n' "$_nfterr" >&2
			return 1
			;;
		esac
	done
}
# Helper: append a warning to both stderr (journalctl) and the warnings file.
warn() {
	echo "$1" >&2
	printf '%s\n' "$1" >> "$WARN_FILE"
}

# Loading the ruleset needs root; a render-only run (validate/plan/tests) is
# read-only and does not, so it can run unprivileged.
if [ -z "${RENDER_ONLY:-}" ] && [ "$(id -u)" -ne 0 ]; then
	echo "Run as root." >&2
	exit 1
fi

if [ -r "$CONFIG_FILE" ]; then
	. "$CONFIG_FILE"
fi

# Derive the NFLOG suffix after the config is sourced, so a config override of
# NFLOG_GROUP (e.g. NFLOG_GROUP="0" to disable) actually takes effect.
case "$NFLOG_GROUP" in ''|*[!0-9]*) NFLOG_GROUP=0 ;; esac
NFLOG_SUFFIX=""
[ "$NFLOG_GROUP" -gt 0 ] && NFLOG_SUFFIX=" group ${NFLOG_GROUP}"

case "$DEFAULT_INPUT" in
	accept|drop) ;;
	*) echo "DEFAULT_INPUT must be 'accept' or 'drop' (got '${DEFAULT_INPUT}')" >&2; exit 1 ;;
esac
case "$DEFAULT_OUTPUT" in
	accept|drop) ;;
	*) echo "DEFAULT_OUTPUT must be 'accept' or 'drop' (got '${DEFAULT_OUTPUT}')" >&2; exit 1 ;;
esac
case "$DEFAULT_FORWARD" in
	accept|drop) ;;
	*) echo "DEFAULT_FORWARD must be 'accept' or 'drop' (got '${DEFAULT_FORWARD}')" >&2; exit 1 ;;
esac

# Group/region definitions can also live in drop-in files. Sourced after the
# main config, in sorted filename order (last definition of a variable wins).
if [ -d "$GROUPS_DIR" ]; then
	for _gf in "$GROUPS_DIR"/*.conf; do
		[ -r "$_gf" ] && . "$_gf"
	done
fi

# UI-managed abuse feed URLs (nftgeo-ui Reference tab) are appended to any
# ABUSE_FEEDS from config, so the panel can add custom blocklists without
# overwriting the config's list. Fetched/parsed exactly like ABUSE_FEEDS.
if [ -n "${ABUSE_FEEDS_UI:-}" ]; then
	ABUSE_FEEDS="${ABUSE_FEEDS:-} ${ABUSE_FEEDS_UI}"
fi

if [ -n "${RENDER_ONLY:-}" ]; then
	# Render is read-only: only the zone dir is read; don't touch STATE_DIR or the
	# live nft path (which may be root-owned and irrelevant to a render).
	mkdir -p "$ZONE_DIR" 2>/dev/null || true
else
	mkdir -p "$STATE_DIR" "$ZONE_DIR" "$(dirname "$NFT_FILE")"
fi

# RENDER_ONLY renders and validates the ruleset without loading it (used by
# "nftgeo validate" / "nftgeo plan"): skip the lock, the AbuseIPDB/feed network
# fetches, and the live load below.
RENDER_ONLY="${RENDER_ONLY:-}"
RENDER_OUT="${RENDER_OUT:-}"

# Serialize runs: the systemd timer and a manual invocation must not rebuild and
# load the ruleset at the same time. Wait briefly for an in-flight run, then give
# up rather than race it.
if [ -z "$RENDER_ONLY" ]; then
	LOCK_FILE="${LOCK_FILE:-${STATE_DIR}/.lock}"
	LOCK_WAIT="${LOCK_WAIT:-60}"
	exec 9>"$LOCK_FILE"
	if ! flock -w "$LOCK_WAIT" 9; then
		echo "Another nftgeo-update is running (lock ${LOCK_FILE}); giving up." >&2
		exit 1
	fi
fi

IPV4_RE='^([0-9]{1,3}\.){3}[0-9]{1,3}(/[0-9]{1,2})?$'
# IPv6: groups of 1-4 hex digits separated by colons, with optional ::
# zero-compression and optional /prefix (0-128). Rejects groups >4 hex chars
# and non-hex characters that the old regex let through. Extreme edge cases
# (e.g. >8 groups) are caught by nft -c downstream.
IPV6_RE='^[0-9a-fA-F]{1,4}(:[0-9a-fA-F]{0,4})*(/[0-9]{1,3})?$|^::([0-9a-fA-F]{1,4}(:[0-9a-fA-F]{0,4})*)?(/[0-9]{1,3})?$'
TAB="$(printf '\t')"

RULES_NORM="${TMP_DIR}/rules.norm"
INGRESS_NORM="${TMP_DIR}/ingress.norm"
THROTTLE_NORM="${TMP_DIR}/throttle.norm"
SYNPROXY_NORM="${TMP_DIR}/synproxy.norm"
NAT_NORM="${TMP_DIR}/nat.norm"
ZONE_NORM="${TMP_DIR}/zone.norm"
ZONE_SEG_IF="${TMP_DIR}/zone.segif"
GEO_TOKENS="${TMP_DIR}/geo.tokens"
GEO_FINAL="${TMP_DIR}/geo.final"
NEEDED_CC="${TMP_DIR}/cc.needed"

sanitize_lower() {
	printf '%s' "$1" | tr 'A-Z' 'a-z' | tr -cs 'a-z0-9' '_' | sed 's/^_//; s/_*$//'
}

resolve_region() {
	u="$(printf '%s' "$1" | tr 'a-z' 'A-Z' | tr -cs 'A-Z0-9_' '_')"
	_val=""
	eval "_val=\"\${REGION_${u}:-}\""
	printf '%s' "$_val"
}

resolve_group() {
	u="$(printf '%s' "$1" | tr 'a-z' 'A-Z' | tr -cs 'A-Z0-9_' '_')"
	_val=""
	eval "_val=\"\${GROUP_${u}:-}\""
	printf '%s' "$_val"
}

resolve_list() {
	u="$(printf '%s' "$1" | tr 'a-z' 'A-Z' | tr -cs 'A-Z0-9_' '_')"
	_val=""
	eval "_val=\"\${LIST_${u}:-}\""
	printf '%s' "$_val"
}

resolve_service() {
	u="$(printf '%s' "$1" | tr 'a-z' 'A-Z' | tr -cs 'A-Z0-9_' '_')"
	_ov=""
	eval "_ov=\"\${SERVICE_${u}:-}\""
	if [ -n "$_ov" ]; then printf '%s' "$_ov"; return 0; fi
	# Fall back to the built-in catalog (a user SERVICE_ above always wins).
	_ln="$(printf '%s' "$1" | tr 'A-Z' 'a-z')"
	for _bs in $BUILTIN_SERVICES; do
		case "$_bs" in "${_ln}:"*) printf '%s' "${_bs#*:}"; return 0 ;; esac
	done
}

resolve_host_label() {
	# HOST_<NAME> = a named single IP/CIDR (or a few), usable as a rule target.
	u="$(printf '%s' "$1" | tr 'a-z' 'A-Z' | tr -cs 'A-Z0-9_' '_')"
	_val=""
	eval "_val=\"\${HOST_${u}:-}\""
	printf '%s' "$_val"
}

resolve_zone() {
	# ZONE_<NAME> = a space-separated list of interfaces (incl. VLAN
	# subinterfaces like eth0.100), the members of a network segment.
	u="$(printf '%s' "$1" | tr 'a-z' 'A-Z' | tr -cs 'A-Z0-9_' '_')"
	_val=""
	eval "_val=\"\${ZONE_${u}:-}\""
	printf '%s' "$_val"
}

iface_set() {
	# Turn a space-separated interface list into an nft ifname match: a single
	# name stays bare, several become an anonymous set { "a", "b" }.
	_n=0; for _i in $1; do _n=$((_n + 1)); done
	if [ "$_n" = 1 ]; then
		printf '"%s"' "$1"
	else
		_out=""; for _i in $1; do _out="${_out}${_out:+, }\"${_i}\""; done
		printf '{ %s }' "$_out"
	fi
}

add_one_member() {
	# $1 geosan, $2 single token: literal IPv4/IPv6 (with optional mask),
	# country code, or region name. Records it in GEO_TOKENS (+ NEEDED_CC for
	# countries). Returns failure if the token is none of these.
	case "$2" in
		*:*)
			printf '%s' "$2" | grep -Eiq "$IPV6_RE" || return 1
			printf '%s\t%s\t%s\n' "$1" v6 "$2" >> "$GEO_TOKENS"
			return 0
			;;
		*.*)
			printf '%s' "$2" | grep -Eq "$IPV4_RE" || return 1
			printf '%s\t%s\t%s\n' "$1" v4 "$2" >> "$GEO_TOKENS"
			return 0
			;;
	esac
	mlc="$(printf '%s' "$2" | tr 'A-Z' 'a-z')"
	mregion="$(resolve_region "$mlc")"
	if [ -n "$mregion" ]; then
		for mc in $mregion; do
			printf '%s\t%s\t%s\n' "$1" cc "$mc" >> "$GEO_TOKENS"
			echo "$mc" >> "$NEEDED_CC"
		done
		return 0
	fi
	case "$mlc" in
		[a-z][a-z])
			printf '%s\t%s\t%s\n' "$1" cc "$mlc" >> "$GEO_TOKENS"
			echo "$mlc" >> "$NEEDED_CC"
			return 0
			;;
	esac
	return 1
}

add_geo_members() {
	# $1 geosan (group key), $2 comma-separated target spec. Each token may be a
	# literal IPv4/IPv6 address or subnet, a country code, a region name, or the
	# name of a GROUP_<NAME> list defined in the config (which expands to any mix
	# of IPs, countries, and regions). Members are recorded in GEO_TOKENS as
	# "geosan<TAB>kind<TAB>value" (kind = cc | v4 | v6). A GROUP_/REGION_ name
	# takes precedence over a country code of the same name. Returns failure on an
	# invalid token.
	gs="$1"
	found=0
	oldifs=$IFS
	IFS=','
	for tok in $2; do
		IFS=$oldifs
		tok="$(printf '%s' "$tok" | tr -d '[:space:]')"
		if [ -z "$tok" ]; then
			IFS=','
			continue
		fi
		case "$tok" in
			*:*|*.*)
				add_one_member "$gs" "$tok" || return 1
				found=1
				;;
			*)
				grp="$(resolve_group "$tok")"
				lst="$(resolve_list "$tok")"
				hst="$(resolve_host_label "$tok")"
				if [ -n "$grp" ]; then
					for m in $(printf '%s' "$grp" | tr ',' ' '); do
						add_one_member "$gs" "$m" || { echo "group '${tok}' has invalid member '${m}'" >&2; return 1; }
						found=1
					done
				elif [ -n "$lst" ]; then
					for m in $(printf '%s' "$lst" | tr ',' ' '); do
						add_one_member "$gs" "$m" || { echo "list '${tok}' has invalid member '${m}'" >&2; return 1; }
						found=1
					done
				elif [ -n "$hst" ]; then
					for m in $(printf '%s' "$hst" | tr ',' ' '); do
						add_one_member "$gs" "$m" || { echo "host '${tok}' has invalid member '${m}'" >&2; return 1; }
						found=1
					done
				else
					add_one_member "$gs" "$tok" || return 1
					found=1
				fi
				;;
		esac
		IFS=','
	done
	IFS=$oldifs
	[ "$found" = 1 ]
}

valid_port() {
	# single port N or range N-M (1..65535, N<=M)
	printf '%s' "$1" | grep -Eq '^[0-9]+(-[0-9]+)?$' || return 1
	case "$1" in
		*-*)
			lo=${1%-*}; hi=${1#*-}
			[ "$lo" -ge 1 ] && [ "$hi" -le 65535 ] && [ "$lo" -le "$hi" ] || return 1
			;;
		*)
			[ "$1" -ge 1 ] && [ "$1" -le 65535 ] || return 1
			;;
	esac
}

expand_service_leaves() {
	# $1: a port field - a number N, a range N-M, an optional /proto suffix
	# (N/tcp, N-M/udp), a comma/space list, or the name of a SERVICE_<NAME> (which
	# may nest more of the same). Echoes a space-separated list of leaf tokens,
	# each "port" or "port/proto"; returns 1 if any leaf is not a valid port or
	# known service. $2 is an internal recursion guard. Recursive calls run in $()
	# subshells, so the shared variable names below are safe across the recursion.
	_d="${2:-0}"
	[ "$_d" -ge 10 ] && return 1
	_acc=""
	for _t in $(printf '%s' "$1" | tr ',' ' '); do
		case "$_t" in
			*/tcp|*/udp|*/sctp) _pp="${_t##*/}"; _pnum="${_t%/*}" ;;
			*)                  _pp="";          _pnum="$_t" ;;
		esac
		if printf '%s' "$_pnum" | grep -Eq '^[0-9]+(-[0-9]+)?$'; then
			valid_port "$_pnum" || return 1
			_acc="${_acc} ${_t}"
		else
			# a service reference (no /proto suffix allowed on a name)
			[ -z "$_pp" ] || return 1
			_sv="$(resolve_service "$_pnum")"
			[ -n "$_sv" ] || return 1
			_sub="$(expand_service_leaves "$_sv" "$((_d + 1))")" || return 1
			_acc="${_acc} ${_sub}"
		fi
	done
	_acc="${_acc# }"
	[ -n "$_acc" ] || return 1
	printf '%s' "$_acc"
}

resolve_service_field() {
	# $1 rule proto (tcp|udp|sctp|all|any), $2 port/service field. Splits the field
	# into per-protocol port sets and echoes one "<proto> <comma-ports>" line per
	# non-empty protocol. Bare (untagged) ports take the rule proto (all|any -> both
	# tcp and udp); a /proto-tagged port that conflicts with a specific rule proto
	# is an error. Returns 1 on any invalid or conflicting member.
	_rp="$1"
	_leaves="$(expand_service_leaves "$2" 0)" || return 1
	_tcp=""; _udp=""; _sctp=""
	for _lf in $_leaves; do
		case "$_lf" in
			*/tcp)  _tag=tcp;  _pt="${_lf%/tcp}" ;;
			*/udp)  _tag=udp;  _pt="${_lf%/udp}" ;;
			*/sctp) _tag=sctp; _pt="${_lf%/sctp}" ;;
			*)      _tag="";   _pt="$_lf" ;;
		esac
		if [ -n "$_tag" ]; then
			case "$_rp" in
				all|any) : ;;
				"$_tag")  : ;;
				*) return 1 ;;   # e.g. a /udp member in a "proto tcp" rule
			esac
			_dst="$_tag"
		else
			case "$_rp" in
				tcp) _dst=tcp ;; udp) _dst=udp ;; sctp) _dst=sctp ;;
				all|any) _dst=both ;;
			esac
		fi
		case "$_dst" in
			tcp)  _tcp="${_tcp},${_pt}" ;;
			udp)  _udp="${_udp},${_pt}" ;;
			sctp) _sctp="${_sctp},${_pt}" ;;
			both) _tcp="${_tcp},${_pt}"; _udp="${_udp},${_pt}" ;;
		esac
	done
	[ -n "${_tcp}${_udp}${_sctp}" ] || return 1
	[ -n "$_tcp" ]  && printf 'tcp %s\n'  "${_tcp#,}"
	[ -n "$_udp" ]  && printf 'udp %s\n'  "${_udp#,}"
	[ -n "$_sctp" ] && printf 'sctp %s\n' "${_sctp#,}"
	return 0
}

l4_match() {
	# $1 proto, $2 port, $3 family (4|6). Echo the protocol/port match clause for
	# that family, the literal "any" when the rule should match every
	# protocol/port on that family, or nothing if the protocol does not apply to
	# that family.
	case "$1" in
		any)          printf 'any' ;;
		tcp|udp|sctp)
			case "$2" in
				-)   printf 'meta l4proto %s' "$1" ;;   # every port of this proto
				*,*) printf '%s dport { %s }' "$1" "$2" ;;
				*)   printf '%s dport %s' "$1" "$2" ;;
			esac
			;;
		all)          printf 'meta l4proto { tcp, udp }' ;;   # portless "all" = every tcp/udp port
		esp|ah|gre)   printf 'meta l4proto %s' "$1" ;;
		icmp)   [ "$3" = 4 ] && printf 'meta l4proto icmp' || true ;;
		icmpv6) [ "$3" = 6 ] && printf 'meta l4proto icmpv6' || true ;;
	esac
}

set_name() {
	# $1 geosan, $2 family (4|6). Echo the nftables set name for the target: the
	# AbuseIPDB blacklist for the reserved "abuse" target, otherwise the geo set.
	if [ "$1" = abuse ]; then
		printf 'abuse%s' "$2"
	else
		printf 'g_%s%s' "$1" "$2"
	fi
}

zone_l4() {
	# $1 proto, $2 port. Echo a single family-agnostic L4 clause for a zone rule,
	# or nothing to match every protocol/port. icmpv6 is inherently v6.
	case "$1" in
		icmpv6) l4_match icmpv6 "$2" 6 ;;
		*) _c="$(l4_match "$1" "$2" 4)"; [ "$_c" = any ] && _c=""; printf '%s' "$_c" ;;
	esac
}

thr_key() {
	# $1 proto, $2 port field. Echo a safe set-name key, e.g. tcp_22, tcp_1000_2000.
	printf 'thr_m_%s_%s' "$1" "$(printf '%s' "$2" | tr -cs 'a-zA-Z0-9' '_' | sed 's/_*$//')"
}

emit_set_match() {
	# $1 l4 match (from l4_match: a clause, "any", or empty), $2 ipver (ip|ip6),
	# $3 address side (saddr|daddr), $4 set name, $5 verdict (accept|drop),
	# $6 iface clause, $7 source comment, $8 rule name (for the log),
	# $9 per-rule log flag (1|0). Emits nothing when the l4 match is empty.
	[ -n "$1" ] || return 0
	ifc="${6:-}"; [ -n "$ifc" ] && ifc="${ifc} "
	if [ "$1" = any ]; then
		mpfx="${ifc}$2 $3 @$4"
	else
		mpfx="${ifc}$1 $2 $3 @$4"
	fi
	# Log when the rule carries "log" ($9), or (for a drop) when LOG_DROPS is set.
	if [ "${9:-0}" = 1 ] || { [ "$5" = drop ] && [ -n "$LOG_DROPS" ]; }; then
		# Log label: the rule's name if it has one, else the policy category.
		if [ -n "${8:-}" ]; then
			_lr="$8"
		else
			case "$4" in abuse*) _lr=abuse ;; g_*) _lr=geo ;; *) [ "$5" = accept ] && _lr=allow || _lr=drop ;; esac
		fi
		_pfx="$LOG_PREFIX_BASE"; [ "$5" = accept ] && _pfx="nftgeo-accept"
		printf '\t\t%s %s log prefix "%s:%s "%s\n' "$mpfx" "$LOG_LIMIT" "$_pfx" "$_lr" "$NFLOG_SUFFIX"
	fi
	if [ -n "${7:-}" ]; then
		printf '\t\t%s counter %s comment "%s"\n' "$mpfx" "$5" "$7"
	else
		printf '\t\t%s counter %s\n' "$mpfx" "$5"
	fi
}

rule_comment() {
	# $1..$5 = action dir proto port target, $6 = iface ("-"/name). Echo the source
	# rules.conf line as "nftgeo:<line>" - stamped on every generated nft rule so
	# the dashboard can read exact per-rule counters via `nft -j` (no guessing). The
	# UI builds the identical string from the same fields.
	_c="$1 $2 $3 $4 $5"
	[ "$6" != "-" ] && [ -n "$6" ] && _c="$_c on $6"
	printf 'nftgeo:%s' "$_c"
}

emit_norm() {
	# action hook side proto port geosan iface log [meta]. The meta (name|src,
	# with spaces) is last so a plain `read ... meta` absorbs it intact; the log
	# flag (0/1) is a single token before it.
	printf '%s %s %s %s %s %s %s %s %s\n' "$1" "$2" "$3" "$4" "$5" "$6" "$7" "${8:-0}" "${9:-}" >> "$RULES_NORM"
}

if_match() {
	# $1 side (saddr|daddr), $2 iface ("-" or a name). Echo the interface match
	# clause (iifname for the source side, oifname for the destination) or nothing.
	[ "$2" = "-" ] && return 0
	case "$1" in
		saddr) printf 'iifname "%s"' "$2" ;;
		daddr) printf 'oifname "%s"' "$2" ;;
	esac
}

parse_rules_file() {
	rf="$1"
	lineno=0
	# The "|| [ -n ... ]" keeps the last line even when the file has no trailing
	# newline (read returns non-zero there but still populates the fields).
	while IFS=" ${TAB}" read -r action dir proto port geo _rest || [ -n "${action}${dir}${proto}${port}${geo}${_rest}" ]; do
		lineno=$((lineno + 1))
		case "$action" in ''|\#*) continue ;; esac

		# Egress NAT (P3). Forms (the WAN/outbound interface is required; the
		# LAN/inbound interface is optional - masquerade on the WAN already scopes
		# it correctly, "in <lan>" just restricts which source interface is NAT'd):
		#   masquerade on <wan> [in <lan>]         -> [iifname <lan>] oifname <wan> masquerade
		#   snat out on <wan> to <ip> [in <lan>]   -> [iifname <lan>] oifname <wan> snat to <ip>
		# Re-tokenize the whole line (the fixed 6-field read doesn't fit these).
		if [ "$action" = masquerade ] || [ "$action" = snat ]; then
			# shellcheck disable=SC2086
			set -- $action $dir $proto $port $geo ${_rest%%#*}
			_mkind="$1"; _mlan="-"; _mip=""
			if [ "$_mkind" = masquerade ]; then
				[ "$2" = on ] && [ -n "${3:-}" ] || { echo "${rf}:${lineno}: usage: masquerade on <wan> [in <lan>]" >&2; exit 1; }
				_mwan="$3"; shift 3
			else
				[ "$2" = out ] && [ "$3" = on ] && [ -n "${4:-}" ] && [ "$5" = to ] && [ -n "${6:-}" ] || {
					echo "${rf}:${lineno}: usage: snat out on <wan> to <ip> [in <lan>]" >&2; exit 1; }
				_mwan="$4"; _mip="$6"; shift 6
			fi
			if [ $# -gt 0 ]; then
				[ "$1" = in ] && [ -n "${2:-}" ] || { echo "${rf}:${lineno}: expected 'in <lan>' after ${_mkind} rule" >&2; exit 1; }
				_mlan="$2"
			fi
			for _mif in "$_mwan" "$_mlan"; do
				[ "$_mif" = "-" ] && continue
				case "$_mif" in *[!A-Za-z0-9._@:-]*) echo "${rf}:${lineno}: bad interface '${_mif}'" >&2; exit 1 ;; esac
			done
			if [ "$_mkind" = masquerade ]; then
				printf 'masquerade %s %s\n' "$_mwan" "$_mlan" >> "$NAT_NORM"
			else
				printf '%s' "$_mip" | grep -Eq "$IPV4_RE" || printf '%s' "$_mip" | grep -Eiq "$IPV6_RE" || {
					echo "${rf}:${lineno}: snat target '${_mip}' must be an IP address" >&2; exit 1; }
				printf 'snat %s %s %s\n' "$_mwan" "$_mlan" "$_mip" >> "$NAT_NORM"
			fi
			continue
		fi

		# Ingress NAT / port-forward (P4). Form:
		#   dnat <proto> <port> to <ip>[:<port>] [from <geo>] [on <iface>]
		# -> prerouting: [iifname <if>] [<fam> saddr @g_<geo>] <proto> dport <port>
		#    dnat to <ip>[:<port>]. The forward policy is accept, so it passes.
		if [ "$action" = dnat ]; then
			_dusage="usage: dnat <proto> <port> to <ip>[:<port>] [from <geo>] [on <iface>]"
			# shellcheck disable=SC2086
			set -- $action $dir $proto $port $geo ${_rest%%#*}
			_dproto="$2"; _dport="$3"
			case "$_dproto" in tcp|udp) ;; *) echo "${rf}:${lineno}: dnat proto must be tcp or udp" >&2; exit 1 ;; esac
			case "$_dport" in ''|*[!0-9]*) echo "${rf}:${lineno}: dnat port '${_dport}' must be a single numeric port" >&2; exit 1 ;; esac
			shift 3
			# Consume "to <target>" and optional "from <geo>" / "on <iface>", any order.
			_tgt=""; _diface=""; _dgeo=""
			while [ $# -gt 0 ]; do
				case "$1" in
					to)   [ -n "${2:-}" ] || { echo "${rf}:${lineno}: ${_dusage}" >&2; exit 1; }; _tgt="$2"; shift 2 ;;
					from) [ -n "${2:-}" ] || { echo "${rf}:${lineno}: ${_dusage}" >&2; exit 1; }; _dgeo="$2"; shift 2 ;;
					on)   [ -n "${2:-}" ] || { echo "${rf}:${lineno}: ${_dusage}" >&2; exit 1; }; _diface="$2"; shift 2 ;;
					*) echo "${rf}:${lineno}: unexpected '${1}' in dnat rule (${_dusage})" >&2; exit 1 ;;
				esac
			done
			[ -n "$_tgt" ] || { echo "${rf}:${lineno}: ${_dusage}" >&2; exit 1; }
			if [ -n "$_diface" ]; then
				case "$_diface" in *[!A-Za-z0-9._@:-]*) echo "${rf}:${lineno}: bad interface '${_diface}'" >&2; exit 1 ;; esac
			fi
			# Split target into address and optional port: v4[:port] or [v6]:port or bare.
			case "$_tgt" in
				\[*\]:*) _dip="${_tgt#\[}"; _dip="${_dip%%\]:*}"; _dtport="${_tgt##*\]:}" ;;
				*.*.*.*:*) _dip="${_tgt%:*}"; _dtport="${_tgt##*:}" ;;
				*) _dip="$_tgt"; _dtport="-" ;;
			esac
			printf '%s' "$_dip" | grep -Eq "$IPV4_RE" || printf '%s' "$_dip" | grep -Eiq "$IPV6_RE" || {
				echo "${rf}:${lineno}: dnat target '${_dip}' must be an IP address" >&2; exit 1; }
			case "$_dtport" in -) ;; *[!0-9]*) echo "${rf}:${lineno}: dnat target port '${_dtport}' must be numeric" >&2; exit 1 ;; esac
			# Optional source-geo restriction (reuse the geo-set machinery).
			_dgeosan="-"
			if [ -n "$_dgeo" ]; then
				_dgeosan="$(sanitize_lower "$_dgeo")"
				add_geo_members "$_dgeosan" "$_dgeo" || { echo "${rf}:${lineno}: bad geo '${_dgeo}' (country, region, IP, IP/mask, or group)" >&2; exit 1; }
			fi
			printf 'dnat %s %s %s %s %s %s\n' "$_dproto" "$_dport" "$_dip" "$_dtport" "${_diface:--}" "$_dgeosan" >> "$NAT_NORM"
			continue
		fi

		# Reactive throttle: rate-limit a port per source and auto-ban offenders.
		# Form: throttle <in|fwd-in> <tcp|udp> <port> <N/second|minute|hour>
		#       [ban <dur>] [on <iface>]. Here dir=$dir, proto=$proto, port=$port,
		# and the rate arrives in the target field ($geo).
		if [ "$action" = throttle ]; then
			case "$dir" in
				in)     _thook=input ;;
				fwd-in) _thook=forward ;;
				*) echo "${rf}:${lineno}: throttle supports only 'in' or 'fwd-in'" >&2; exit 1 ;;
			esac
			case "$proto" in tcp|udp) ;; *) echo "${rf}:${lineno}: throttle needs proto 'tcp' or 'udp'" >&2; exit 1 ;; esac
			printf '%s' "$port" | grep -Eq '^[0-9]+(-[0-9]+)?(,[0-9]+(-[0-9]+)?)*$' || {
				echo "${rf}:${lineno}: throttle port '${port}' must be a number, range (N-M) or list" >&2; exit 1; }
			printf '%s' "$geo" | grep -Eq '^[0-9]+/(second|minute|hour)$' || {
				echo "${rf}:${lineno}: throttle rate '${geo}' must be like 5/minute (N/second|minute|hour)" >&2; exit 1; }
			_tban="$THROTTLE_BAN"; _tiface="-"
			set -- ${_rest%%#*}
			while [ $# -gt 0 ]; do
				case "$1" in
					ban) _tban="${2:-}"
						printf '%s' "$_tban" | grep -Eq '^[0-9]+[smhd]$' || {
							echo "${rf}:${lineno}: throttle 'ban' needs a duration like 30m/1h/2d" >&2; exit 1; }
						shift 2 ;;
					on) _tiface="${2:-}"
						case "$_tiface" in ''|*[!A-Za-z0-9._@:-]*) echo "${rf}:${lineno}: 'on' needs a valid interface name" >&2; exit 1 ;; esac
						shift 2 ;;
					*) echo "${rf}:${lineno}: unexpected '${1}' in throttle rule (only 'ban <dur>' / 'on <iface>')" >&2; exit 1 ;;
				esac
			done
			printf '%s saddr %s %s %s %s %s\n' "$_thook" "$proto" "$port" "$geo" "$_tban" "$_tiface" >> "$THROTTLE_NORM"
			continue
			fi

			# SYN-flood protection via synproxy. Form:
			#   synproxy tcp <port> [on <iface>]
			# Emits a synproxy rule in the input (or forward) chain before the
			# allow rules.  synproxy handles the SYN/SYN-ACK/ACK handshake in
			# the kernel, dropping spoofed SYNs that never complete it.
			if [ "$action" = synproxy ]; then
				case "$dir" in
					in)     _shook=input ;;
					fwd-in) _shook=forward ;;
					*) echo "${rf}:${lineno}: synproxy supports only 'in' or 'fwd-in'" >&2; exit 1 ;;
				esac
				case "$proto" in tcp) ;; *) echo "${rf}:${lineno}: synproxy needs proto 'tcp'" >&2; exit 1 ;; esac
				printf '%s' "$port" | grep -Eq '^[0-9]+(-[0-9]+)?(,[0-9]+(-[0-9]+)?)*$' || {
					echo "${rf}:${lineno}: synproxy port '${port}' must be a number, range (N-M) or list" >&2; exit 1; }
				_siface="-"
				# The optional "on <iface>" lands in $geo + $_rest after the fixed
				# 6-field read, so re-tokenize from $geo onward (not just $_rest).
				# shellcheck disable=SC2086
				set -- $geo ${_rest%%#*}
				while [ $# -gt 0 ]; do
					case "$1" in
						on) _siface="${2:-}"
							case "$_siface" in ''|*[!A-Za-z0-9._@:-]*) echo "${rf}:${lineno}: 'on' needs a valid interface name" >&2; exit 1 ;; esac
							shift 2 ;;
						*) echo "${rf}:${lineno}: unexpected '${1}' in synproxy rule (only 'on <iface>')" >&2; exit 1 ;;
					esac
				done
				printf '%s %s %s\n' "$_shook" "$port" "$_siface" >> "$SYNPROXY_NORM"
				continue
			fi

			# Inter-zone rule (P5): "<allow|deny> <zone> -> <zone> <proto> <port> [from <geo>]".
		# Detected by the "->" separator; builds forward-chain rules matching the
		# source zone's interfaces (iifname) against the destination zone's (oifname).
		if { [ "$action" = allow ] || [ "$action" = deny ]; }; then
			# shellcheck disable=SC2086
			set -- $action $dir $proto $port $geo ${_rest%%#*}
			if [ "${3:-}" = "->" ]; then
				_zaction="$1"; _zsrc="$2"; _zdst="$4"; _zproto="${5:-}"; _zport="${6:-}"; _zgeo=""
				[ -n "$_zproto" ] || { echo "${rf}:${lineno}: usage: ${_zaction} <zone> -> <zone> <proto> <port> [from <geo>]" >&2; exit 1; }
				if [ -n "${7:-}" ]; then
					[ "$7" = from ] && [ -n "${8:-}" ] || { echo "${rf}:${lineno}: usage: ${_zaction} <zone> -> <zone> <proto> <port> [from <geo>]" >&2; exit 1; }
					_zgeo="$8"
				fi
				# Resolve each zone name to its interface list ("any" = unconstrained).
				if [ "$_zsrc" = any ]; then _zsrcif=""; else
					_zsrcif="$(resolve_zone "$_zsrc")"
					[ -n "$_zsrcif" ] || { echo "${rf}:${lineno}: unknown source zone '${_zsrc}' (define ZONE_$(printf '%s' "$_zsrc" | tr 'a-z' 'A-Z') in config)" >&2; exit 1; }
				fi
				if [ "$_zdst" = any ]; then _zdstif=""; else
					_zdstif="$(resolve_zone "$_zdst")"
					[ -n "$_zdstif" ] || { echo "${rf}:${lineno}: unknown destination zone '${_zdst}' (define ZONE_$(printf '%s' "$_zdst" | tr 'a-z' 'A-Z') in config)" >&2; exit 1; }
				fi
				for _i in $_zsrcif $_zdstif; do printf '%s\n' "$_i" >> "$ZONE_SEG_IF"; done
				# Proto/port buckets, same grammar as a normal rule.
				_zportless=""; _zbuckets=""
				case "$_zproto" in
					tcp|udp|sctp|all)
						case "$_zport" in ''|-|any) echo "${rf}:${lineno}: proto '${_zproto}' needs a port or service" >&2; exit 1 ;; esac
						_zbuckets="$(resolve_service_field "$_zproto" "$_zport")" || { echo "${rf}:${lineno}: bad port/service '${_zport}'" >&2; exit 1; } ;;
					any)
						case "$_zport" in ''|-|any) _zport=-; _zportless=yes ;;
							*) _zbuckets="$(resolve_service_field any "$_zport")" || { echo "${rf}:${lineno}: bad port/service '${_zport}'" >&2; exit 1; } ;;
						esac ;;
					icmp|icmpv6|esp|ah|gre)
						case "$_zport" in ''|-|any) _zport=-; _zportless=yes ;; *) echo "${rf}:${lineno}: proto '${_zproto}' takes no port (use -)" >&2; exit 1 ;; esac ;;
					*) echo "${rf}:${lineno}: bad proto '${_zproto}' (tcp|udp|sctp|all|any|icmp|icmpv6|esp|ah|gre)" >&2; exit 1 ;;
				esac
				# Optional source-geo restriction.
				_zgeosan="-"
				if [ -n "$_zgeo" ]; then
					_zgeosan="$(sanitize_lower "$_zgeo")"
					add_geo_members "$_zgeosan" "$_zgeo" || { echo "${rf}:${lineno}: bad geo '${_zgeo}' (country, region, IP, IP/mask, or group)" >&2; exit 1; }
				fi
				# Interface lists collapse to a comma field ("-" = unconstrained).
				_zs="$(echo $_zsrcif | tr ' ' ',')"; [ -z "$_zs" ] && _zs="-"
				_zd="$(echo $_zdstif | tr ' ' ',')"; [ -z "$_zd" ] && _zd="-"
				if [ -n "$_zportless" ]; then
					printf '%s %s %s %s %s %s\n' "$_zaction" "$_zs" "$_zd" "$_zproto" "-" "$_zgeosan" >> "$ZONE_NORM"
				else
					printf '%s\n' "$_zbuckets" | while IFS=' ' read -r _bp _bports; do
						[ -n "$_bp" ] || continue
						printf '%s %s %s %s %s %s\n' "$_zaction" "$_zs" "$_zd" "$_bp" "$_bports" "$_zgeosan" >> "$ZONE_NORM"
					done
				fi
				continue
			fi
		fi

		case "$action" in
			allow|deny) ;;
			*) echo "${rf}:${lineno}: bad action '${action}' (allow|deny|throttle)" >&2; exit 1 ;;
		esac
		case "$dir" in
			in)      hook=input;   side=saddr ;;
			out)     hook=output;  side=daddr ;;
			fwd-in)  hook=forward;  side=saddr ;;
			fwd-out) hook=forward;  side=daddr ;;
			*) echo "${rf}:${lineno}: bad direction '${dir}' (use in|out|fwd-in|fwd-out)" >&2; exit 1 ;;
		esac
		# Resolve the port/service field into per-protocol buckets ($_buckets, one
		# "<proto> <ports>" line each) unless the rule is genuinely port-less.
		_portless=""; _buckets=""
		case "$proto" in
			tcp|udp|sctp|all)
				# An empty / "-" / "any" port means every port of this protocol
				# (matched with meta l4proto); otherwise resolve the port/service.
				case "$port" in
					-|any)
						port=-; _portless=yes ;;
					*)
						if ! _buckets="$(resolve_service_field "$proto" "$port")"; then
							echo "${rf}:${lineno}: bad port/service '${port}' (a number, N-M, a list, a SERVICE_ name, or a /tcp|/udp tag conflicting with proto '${proto}')" >&2
							exit 1
						fi
						;;
				esac
				;;
			any)
				# "any -" matches every protocol/port; "any <service>" defers the
				# protocol(s) to the (tagged) service.
				case "$port" in
					-|any) port=-; _portless=yes ;;
					*)
						if ! _buckets="$(resolve_service_field "$proto" "$port")"; then
							echo "${rf}:${lineno}: bad port/service '${port}' (a number, N-M, a list, or a SERVICE_ name)" >&2
							exit 1
						fi
						;;
				esac
				;;
			icmp|icmpv6|esp|ah|gre)
				case "$port" in
					-|any) port=-; _portless=yes ;;
					*) echo "${rf}:${lineno}: proto '${proto}' takes no port (use -)" >&2; exit 1 ;;
				esac
				;;
			*)
				echo "${rf}:${lineno}: bad proto '${proto}' (tcp|udp|sctp|all|any|icmp|icmpv6|esp|ah|gre)" >&2
				exit 1
				;;
		esac
		if [ -z "$geo" ]; then
			echo "${rf}:${lineno}: missing target" >&2
			exit 1
		fi

		if [ "$geo" = "any" ]; then
			geosan="any"
		elif [ "$geo" = "abuse" ]; then
			# Reserved target: the AbuseIPDB blacklist. No address set is built
			# for it; it is populated by fetch_abuseipdb into @abuse4/@abuse6.
			if [ "$action" != "deny" ]; then
				echo "${rf}:${lineno}: target 'abuse' only valid with 'deny'" >&2
				exit 1
			fi
			geosan="abuse"
		else
			geosan="$(sanitize_lower "$geo")"
			if ! add_geo_members "$geosan" "$geo"; then
				echo "${rf}:${lineno}: bad target '${geo}' (country, region, IP, IP/mask, group, any, or abuse)" >&2
				exit 1
			fi
		fi

		# Optional qualifiers after the target, in any order (inline # comment
		# allowed after them): "on <iface>" and "log". "on" maps to iifname on the
		# source side (in/fwd-in) and oifname on the destination side (out/fwd-out);
		# "log" emits a per-rule log prefix (nftgeo-accept:/nftgeo-drop:<name>).
		iface="-"; _rlog=0
		set -- ${_rest%%#*}
		while [ -n "${1:-}" ]; do
			case "$1" in
				on)
					iface="${2:-}"
					case "$iface" in
						''|*[!A-Za-z0-9._@:-]*) echo "${rf}:${lineno}: 'on' needs a valid interface name" >&2; exit 1 ;;
					esac
					if [ ! -e "/sys/class/net/${iface}" ]; then
						case " ${WARNED_IFACES:-} " in
							*" ${iface} "*) : ;;
							*) echo "${rf}:${lineno}: warning: interface '${iface}' is not present; rules on it match nothing until it appears" >&2
							   WARNED_IFACES="${WARNED_IFACES:-} ${iface}" ;;
						esac
					fi
					shift 2 ;;
				log) _rlog=1; shift ;;
				*) echo "${rf}:${lineno}: unexpected '${1}' after target (only 'on <iface>' and 'log' allowed)" >&2; exit 1 ;;
			esac
		done

		# Metadata carried per rule: the rule's name (trailing # comment, used in
		# drop logs) and the source stamp (counter comment for the UI). Packed as
		# "<name>|<src>" into one trailing field; emit_chain splits on the first '|'.
		_src="$(rule_comment "$action" "$dir" "$proto" "$port" "$geo" "$iface")"
		_name=""
		case "$_rest" in
			*"#"*) _name="$(printf '%s' "${_rest#*#}" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//; s/|//g')" ;;
		esac
		_meta="${_name}|${_src}"
		if [ -n "$_portless" ]; then
			# proto any/icmp/icmpv6/esp/ah/gre with no port
			emit_norm "$action" "$hook" "$side" "$proto" "$port" "$geosan" "$iface" "$_rlog" "$_meta"
		else
			# one normalized rule per resolved protocol bucket (tcp/udp/sctp)
			printf '%s\n' "$_buckets" | while IFS=' ' read -r _bp _bports; do
				[ -n "$_bp" ] || continue
				emit_norm "$action" "$hook" "$side" "$_bp" "$_bports" "$geosan" "$iface" "$_rlog" "$_meta"
			done
		fi
	done < "$rf"
}

# parse_ingress_file: ingress hook rules (stateless, source-based, pre-routing).
# Grammar: "<accept|drop> <target> [proto] [port] [log] [# name]". No dir (always
# source), no ct state. Emits INGRESS_NORM lines "action geosan proto port log meta".
parse_ingress_file() {
	rf="$1"; lineno=0
	while IFS= read -r line || [ -n "$line" ]; do
		lineno=$((lineno + 1))
		_body="${line%%#*}"
		case "$_body" in *[!\ ]*) : ;; *) continue ;; esac # blank / comment-only
		_iname=""
		case "$line" in *"#"*) _iname="$(printf '%s' "${line#*#}" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//; s/|//g')" ;; esac
		# shellcheck disable=SC2086
		set -- $_body
		iact="$1"; itgt="${2:-}"
		case "$iact" in
			accept|drop) : ;;
			*) echo "${rf}:${lineno}: ingress rule must start with 'accept' or 'drop'" >&2; exit 1 ;;
		esac
		[ -n "$itgt" ] || { echo "${rf}:${lineno}: missing target" >&2; exit 1; }
		shift 2 2>/dev/null || shift $#
		# Optional [proto [port]] [log], in that order.
		iproto="any"; iport="-"; ilog=0
		case "${1:-}" in
			tcp|udp|sctp|all|any|icmp|icmpv6|esp|ah|gre)
				iproto="$1"; shift
				case "${1:-}" in ''|log) : ;; *) iport="$1"; shift ;; esac ;;
		esac
		[ "${1:-}" = log ] && { ilog=1; shift; }
		[ -n "${1:-}" ] && { echo "${rf}:${lineno}: unexpected '${1}' (grammar: <accept|drop> <target> [proto] [port] [log])" >&2; exit 1; }
		# Resolve the source target into a set name (or the reserved any/abuse).
		if [ "$itgt" = any ]; then
			igeo="any"
		elif [ "$itgt" = abuse ]; then
			[ "$iact" = drop ] || { echo "${rf}:${lineno}: target 'abuse' only valid with 'drop'" >&2; exit 1; }
			igeo="abuse"
		else
			igeo="$(sanitize_lower "$itgt")"
			add_geo_members "$igeo" "$itgt" || { echo "${rf}:${lineno}: bad target '${itgt}'" >&2; exit 1; }
		fi
		_isrc="$(rule_comment "$iact" ingress "$iproto" "$iport" "$itgt" -)"
		_imeta="${_iname}|${_isrc}"
		# Resolve proto/port into buckets (or a portless line), reusing the filter path.
		case "$iproto" in
			tcp|udp|sctp|all)
				case "$iport" in
					-|any) printf '%s %s %s - %s %s\n' "$iact" "$igeo" "$iproto" "$ilog" "$_imeta" >> "$INGRESS_NORM" ;;
					*)
						_ib="$(resolve_service_field "$iproto" "$iport")" || { echo "${rf}:${lineno}: bad port/service '${iport}'" >&2; exit 1; }
						printf '%s\n' "$_ib" | while IFS=' ' read -r _bp _bports; do
							[ -n "$_bp" ] || continue
							printf '%s %s %s %s %s %s\n' "$iact" "$igeo" "$_bp" "$_bports" "$ilog" "$_imeta" >> "$INGRESS_NORM"
						done ;;
				esac ;;
			*) # any/icmp/icmpv6/esp/ah/gre: portless
				printf '%s %s %s - %s %s\n' "$iact" "$igeo" "$iproto" "$ilog" "$_imeta" >> "$INGRESS_NORM" ;;
		esac
	done < "$rf"
}

parse_rules() {
	: > "$RULES_NORM"
	: > "$INGRESS_NORM"
	: > "$THROTTLE_NORM"
	: > "$SYNPROXY_NORM"
	: > "$NAT_NORM"
	: > "$ZONE_NORM"
	: > "$ZONE_SEG_IF"
	: > "$GEO_TOKENS"
	: > "$NEEDED_CC"

	# rules.conf first (if present), then rules.d/*.conf in sorted filename order.
	if [ -r "$RULES_FILE" ]; then
		parse_rules_file "$RULES_FILE"
	fi
	if [ -d "$RULES_DIR" ]; then
		for rf in "$RULES_DIR"/*.conf; do
			[ -r "$rf" ] || continue
			parse_rules_file "$rf"
		done
	fi

	# Ingress hook rules: ingress.conf first, then ingress.d/*.conf in name order.
	if [ -r "$INGRESS_FILE" ]; then
		parse_ingress_file "$INGRESS_FILE"
	fi
	if [ -d "$INGRESS_DIR" ]; then
		for rf in "$INGRESS_DIR"/*.conf; do
			[ -r "$rf" ] || continue
			parse_ingress_file "$rf"
		done
	fi

	if [ ! -s "$RULES_NORM" ] && [ ! -s "$INGRESS_NORM" ] && [ ! -s "$THROTTLE_NORM" ] && [ ! -s "$SYNPROXY_NORM" ] && [ ! -s "$NAT_NORM" ] && [ ! -s "$ZONE_NORM" ]; then
		# No rules at all. With DEFAULT_INPUT=drop this would silently load a
		# default-deny table and lock everyone out, so keep the hard abort there.
		# With DEFAULT_INPUT=accept (the default) an empty ruleset accepts
		# everything — it blocks nothing, so start gracefully and just warn.
		# This lets a fresh install boot cleanly (service active, panel usable)
		# before any rules are added, instead of failing on the empty example.
		if [ "$DEFAULT_INPUT" = drop ]; then
			echo "No rules found in ${RULES_FILE} or ${RULES_DIR}/*.conf, and DEFAULT_INPUT=drop would lock everyone out. Add an allow/whitelist rule, or set DEFAULT_INPUT=accept." >&2
			exit 1
		fi
		# Journal only (echo, not warn): this is the expected fresh-install state,
		# and the dashboard already shows an empty policy list — surfacing it as a
		# panel "engine warning" is just noise for someone editing rules in the UI.
		echo "No rules configured in ${RULES_FILE} or ${RULES_DIR}/*.conf; loading a permissive baseline (DEFAULT_INPUT=accept) that blocks nothing." >&2
		# Emit an input chain anyway so the table is a coherent (if permissive)
		# firewall with a real input hook, not just bare sets — the dashboard's
		# "table loaded" check and the operator both expect an input chain.
		FORCE_INPUT_CHAIN=1
	fi

	sort -u "$GEO_TOKENS" -o "$GEO_TOKENS"
	awk -F'\t' '!seen[$1]++{print $1}' "$GEO_TOKENS" > "$GEO_FINAL"
}

zone_fresh() {
	f="$1"
	[ -s "$f" ] || return 1
	[ -z "$(find "$f" -mmin +"$((ZONE_CACHE_HOURS * 60))" 2>/dev/null)" ]
}

valid_nonnegative_int() {
	case "$1" in
		''|*[!0-9]*) return 1 ;;
		*) return 0 ;;
	esac
}

ensure_zones() {
	[ -s "$NEEDED_CC" ] || return 0
	sort -u "$NEEDED_CC" > "${TMP_DIR}/cc.uniq"

	while read -r cc; do
		[ -n "$cc" ] || continue
		v4="${ZONE_DIR}/${cc}.v4"
		v6="${ZONE_DIR}/${cc}.v6"
		if zone_fresh "$v4"; then
			continue
		fi

		t4="${TMP_DIR}/dl.v4"
		t6="${TMP_DIR}/dl.v6"
		: > "$t4"; : > "$t6"
		curl -fsSL --user-agent "nftgeo/1.45.0" "${IPDENY_V4_URL}/${cc}-aggregated.zone" -o "$t4" 2>/dev/null || true
		curl -fsSL --user-agent "nftgeo/1.45.0" "${IPDENY_V6_URL}/${cc}-aggregated.zone" -o "$t6" 2>/dev/null || true
		grep -E "$IPV4_RE" "$t4" > "${t4}.f" 2>/dev/null || true
		grep -Ei "$IPV6_RE" "$t6" > "${t6}.f" 2>/dev/null || true

		if [ -s "${t4}.f" ]; then
			install -m 0644 "${t4}.f" "$v4"
			install -m 0644 "${t6}.f" "$v6"
			date -u +%s > "${TMP_DIR}/geo_fetched_at"
		elif [ -s "$v4" ]; then
			warn "Zone refresh failed for '${cc}', using cached copy."
		else
			# No data (e.g. ipdeny has no zone for this code) and no cache: skip
			# this country rather than abort. A target that ends up with no usable
			# address at all is still caught by build_geo_sets below, which is the
			# real guard against loading an empty allow set.
			warn "Zone unavailable for country '${cc}' (no data, no cache); skipping it."
		fi
	done < "${TMP_DIR}/cc.uniq"
}

build_geo_sets() {
	while read -r geosan; do
		[ -n "$geosan" ] || continue
		out4="${TMP_DIR}/g_${geosan}.v4"
		out6="${TMP_DIR}/g_${geosan}.v6"
		: > "$out4"; : > "$out6"
		awk -F'\t' -v g="$geosan" '$1==g{print $2"\t"$3}' "$GEO_TOKENS" | while IFS="$TAB" read -r kind value; do
			case "$kind" in
				cc)
					# Use if/fi (not "&& cat"): a missing zone file makes the last
					# "[ -f ] &&" return non-zero, which under set -e would abort the
					# whole run before the empty-set check below can decide.
					if [ -f "${ZONE_DIR}/${value}.v4" ]; then cat "${ZONE_DIR}/${value}.v4" >> "$out4"; fi
					if [ -f "${ZONE_DIR}/${value}.v6" ]; then cat "${ZONE_DIR}/${value}.v6" >> "$out6"; fi
					;;
				v4) echo "$value" >> "$out4" ;;
				v6) echo "$value" >> "$out6" ;;
			esac
		done
		sort -u "$out4" -o "$out4"
		sort -u "$out6" -o "$out6"
		if [ ! -s "$out4" ] && [ ! -s "$out6" ]; then
			# An empty set only closes a port when it backs an "allow" rule (the
			# port is then dropped for everyone). There we keep the fail-safe and
			# abort, leaving the previous ruleset in place. When the group is used
			# only in "deny" rules an empty set drops nothing, so one unresolvable
			# country must not freeze every other rule's update: skip it instead.
			if awk -F' ' -v g="$geosan" '$1=="allow" && $6==g{f=1} END{exit !f}' "$RULES_NORM"; then
				echo "Geo group '${geosan}' produced no addresses and backs an allow rule; aborting to avoid closing a port with an empty allow set." >&2
				exit 1
			fi
			echo "Geo group '${geosan}' produced no addresses; used only in deny rules, so skipping it (it would drop nothing)." >&2
		fi
	done < "$GEO_FINAL"
}

fetch_abuseipdb() {
	: > "${TMP_DIR}/abuse4.set"
	: > "${TMP_DIR}/abuse6.set"
	: > "${TMP_DIR}/abuse.current"

	if [ -z "${ABUSEIPDB_API_KEY:-}" ]; then
		warn "AbuseIPDB API key not set in ${CONFIG_FILE}; abuse sets will be empty. Add ABUSEIPDB_API_KEY to config or via the dashboard."
		return 0
	fi

	if ! valid_nonnegative_int "$ABUSEIPDB_RETENTION_DAYS"; then
		echo "ABUSEIPDB_RETENTION_DAYS must be a non-negative integer." >&2
		exit 1
	fi

	if ! curl -fsS --user-agent "nftgeo/1.45.0" --get "$ABUSEIPDB_URL" \
		--data-urlencode "confidenceMinimum=${ABUSEIPDB_CONFIDENCE_MINIMUM}" \
		--data-urlencode "limit=${ABUSEIPDB_LIMIT}" \
		--data-urlencode "days=${ABUSEIPDB_DAYS}" \
		--data-urlencode "plaintext=true" \
		-H "Key: ${ABUSEIPDB_API_KEY}" \
		-H "Accept: text/plain" > "${TMP_DIR}/abuse.raw"; then
		if [ -s "$ABUSEIPDB_STATE_FILE" ]; then
			warn "AbuseIPDB download failed; using retained state from ${ABUSEIPDB_STATE_FILE}."
			now="$(date +%s)"
			cutoff="$((now - ABUSEIPDB_RETENTION_DAYS * 86400))"
			awk -F'\t' -v cutoff="$cutoff" '$1 != "" && $2 ~ /^[0-9]+$/ && $2 >= cutoff {print $1 "\t" $2}' \
				"$ABUSEIPDB_STATE_FILE" | sort -u > "${TMP_DIR}/abuseipdb.tsv"
			awk -F'\t' '{print $1}' "${TMP_DIR}/abuseipdb.tsv" | sort -u > "${TMP_DIR}/abuse.current"
			grep -E "$IPV4_RE" "${TMP_DIR}/abuse.current" > "${TMP_DIR}/abuse4.set" || true
			grep -Ei "$IPV6_RE" "${TMP_DIR}/abuse.current" > "${TMP_DIR}/abuse6.set" || true
		else
			warn "AbuseIPDB download failed; keeping abuse sets empty for this run."
		fi
		return 0
	fi

	{
		grep -E "$IPV4_RE" "${TMP_DIR}/abuse.raw" || true
		grep -Ei "$IPV6_RE" "${TMP_DIR}/abuse.raw" || true
	} | sort -u > "${TMP_DIR}/abuse.downloaded"

	now="$(date +%s)"
	cutoff="$((now - ABUSEIPDB_RETENTION_DAYS * 86400))"
	old_state="/dev/null"
	[ -s "$ABUSEIPDB_STATE_FILE" ] && old_state="$ABUSEIPDB_STATE_FILE"

	awk -F'\t' -v now="$now" -v cutoff="$cutoff" '
		FNR == NR {
			if ($0 != "") {
				last[$0] = now
				seen[$0] = 1
			}
			next
		}
		$1 != "" && $2 ~ /^[0-9]+$/ && $2 >= cutoff {
			if (!($1 in last)) {
				last[$1] = $2
			}
			seen[$1] = 1
		}
		END {
			for (ip in seen) {
				if (last[ip] >= cutoff) {
					print ip "\t" last[ip]
				}
			}
		}
	' "${TMP_DIR}/abuse.downloaded" "$old_state" | sort -u > "${TMP_DIR}/abuseipdb.tsv"

	awk -F'\t' '{print $1}' "${TMP_DIR}/abuseipdb.tsv" | sort -u > "${TMP_DIR}/abuse.current"
	grep -E "$IPV4_RE" "${TMP_DIR}/abuse.current" > "${TMP_DIR}/abuse4.set" || true
	grep -Ei "$IPV6_RE" "${TMP_DIR}/abuse.current" > "${TMP_DIR}/abuse6.set" || true
	date -u +%s > "${TMP_DIR}/abuse_fetched_at"
}

fetch_abuse_feeds() {
	# Merge extra plaintext IP/CIDR blocklists into the abuse sets. Each feed is
	# downloaded fresh; on failure its last good copy (cached per URL) is reused, so
	# a feed outage never shrinks the blocklist. Comment markers (# and ;) and any
	# text after the address are stripped, covering the common feed formats
	# (FireHOL, Spamhaus DROP, blocklist.de, GreenSnow).
	[ -n "$ABUSE_FEEDS" ] || return 0
	mkdir -p "$ABUSE_FEEDS_CACHE_DIR"

	for url in $ABUSE_FEEDS; do
		[ -n "$url" ] || continue
		cache="${ABUSE_FEEDS_CACHE_DIR}/$(printf '%s' "$url" | tr -c 'A-Za-z0-9' '_')"
		raw="${TMP_DIR}/feed.raw"
		if curl -fsSL --user-agent "nftgeo/1.45.0" "$url" -o "$raw" 2>/dev/null && [ -s "$raw" ]; then
			sed 's/[#;].*//' "$raw" | tr -d '\r' | awk 'NF{print $1}' > "${raw}.f"
			{ grep -E "$IPV4_RE" "${raw}.f" || true; grep -Ei "$IPV6_RE" "${raw}.f" || true; } \
				| sort -u > "${raw}.ok"
			# Cap a single feed so a runaway list can't build a giant, slow set.
			if [ "$ABUSE_FEEDS_MAX" -gt 0 ] 2>/dev/null; then
				_feed_n="$(wc -l < "${raw}.ok")"
				if [ "$_feed_n" -gt "$ABUSE_FEEDS_MAX" ]; then
					echo "Abuse feed '${url}' has ${_feed_n} entries; capping at ABUSE_FEEDS_MAX=${ABUSE_FEEDS_MAX} (raise it in config if the box can handle more)." >&2
					head -n "$ABUSE_FEEDS_MAX" "${raw}.ok" > "${raw}.cap" && mv "${raw}.cap" "${raw}.ok"
				fi
			fi
			[ -s "${raw}.ok" ] && install -m 0644 "${raw}.ok" "$cache"
		elif [ -s "$cache" ]; then
			echo "Abuse feed '${url}' download failed; using cached copy." >&2
		else
			echo "Abuse feed '${url}' unavailable (no data, no cache); skipping." >&2
			continue
		fi
		grep -E "$IPV4_RE" "$cache" >> "${TMP_DIR}/abuse4.set" 2>/dev/null || true
		grep -Ei "$IPV6_RE" "$cache" >> "${TMP_DIR}/abuse6.set" 2>/dev/null || true
	done

	sort -u "${TMP_DIR}/abuse4.set" -o "${TMP_DIR}/abuse4.set"
	sort -u "${TMP_DIR}/abuse6.set" -o "${TMP_DIR}/abuse6.set"
}

scrub_abuse() {
	# Blocklist feeds (e.g. FireHOL level1) and, rarely, APIs include bogon /
	# private / reserved ranges. With a "deny ... abuse" egress rule those would
	# drop traffic to your own loopback resolver (127.0.0.53), LAN, and VPN -
	# silently breaking DNS and local connectivity. Strip every non-public address
	# so the abuse sets only ever hold public, routable addresses.
	v4b='^(0|10|127)\.|^100\.(6[4-9]|[7-9][0-9]|1[01][0-9]|12[0-7])\.|^169\.254\.|^172\.(1[6-9]|2[0-9]|3[01])\.|^192\.0\.[02]\.|^192\.88\.99\.|^192\.168\.|^198\.1[89]\.|^198\.51\.100\.|^203\.0\.113\.|^(22[4-9]|2[3-5][0-9])\.'
	v6b='^::($|1|/|ffff:)|^(fc|fd|fe[89ab]|ff|64:ff9b:|2001:db8:)'
	if [ -s "${TMP_DIR}/abuse4.set" ]; then
		grep -Ev "$v4b" "${TMP_DIR}/abuse4.set" > "${TMP_DIR}/abuse4.scrub" || true
		mv "${TMP_DIR}/abuse4.scrub" "${TMP_DIR}/abuse4.set"
	fi
	if [ -s "${TMP_DIR}/abuse6.set" ]; then
		grep -Evi "$v6b" "${TMP_DIR}/abuse6.set" > "${TMP_DIR}/abuse6.scrub" || true
		mv "${TMP_DIR}/abuse6.scrub" "${TMP_DIR}/abuse6.set"
	fi
	aggregate_abuse
}

aggregate_abuse() {
	# Collapse the abuse addresses into the fewest CIDR ranges. iprange (IPv4) and
	# aggregate6 (IPv6) do this optimally; without them nft's auto-merge still
	# merges at load time, just from a larger file. Big scattered lists shrink a lot.
	[ "$ABUSE_FEEDS_AGGREGATE" = 1 ] || return 0
	if command -v iprange >/dev/null 2>&1 && [ -s "${TMP_DIR}/abuse4.set" ]; then
		_b="$(wc -l < "${TMP_DIR}/abuse4.set")"
		if iprange "${TMP_DIR}/abuse4.set" > "${TMP_DIR}/abuse4.agg" 2>/dev/null && [ -s "${TMP_DIR}/abuse4.agg" ]; then
			mv "${TMP_DIR}/abuse4.agg" "${TMP_DIR}/abuse4.set"
			_a="$(wc -l < "${TMP_DIR}/abuse4.set")"
			[ "$_b" != "$_a" ] && echo "Aggregated abuse IPv4: ${_b} -> ${_a} CIDRs." >&2
		fi
	elif [ -s "${TMP_DIR}/abuse4.set" ] && [ "$(wc -l < "${TMP_DIR}/abuse4.set")" -gt "$ABUSE_FEEDS_MAX" ]; then
		echo "note: 'iprange' not installed; large abuse list loaded un-aggregated (nft auto-merge still applies). Install iprange to shrink it." >&2
	fi
	if command -v aggregate6 >/dev/null 2>&1 && [ -s "${TMP_DIR}/abuse6.set" ]; then
		if aggregate6 < "${TMP_DIR}/abuse6.set" > "${TMP_DIR}/abuse6.agg" 2>/dev/null && [ -s "${TMP_DIR}/abuse6.agg" ]; then
			mv "${TMP_DIR}/abuse6.agg" "${TMP_DIR}/abuse6.set"
		fi
	fi
}

getent_t() {
	# getent, bounded by RESOLVE_TIMEOUT so a hung resolver cannot stall the whole
	# update (the systemd timer run included); a timeout just yields no address.
	if command -v timeout >/dev/null 2>&1; then
		timeout "${RESOLVE_TIMEOUT:-5}" getent "$@"
	else
		getent "$@"
	fi
}

dns_query() {
	# $1 resolver IP, $2 name. Echo A/AAAA addresses using whichever DNS client is
	# present. Needed only for non-"local" entries in RESOLVERS.
	s="$1"; n="$2"; rt="${RESOLVE_TIMEOUT:-5}"
	if command -v dig >/dev/null 2>&1; then
		timeout "$rt" dig +short +tries=1 +time="$rt" "@${s}" A    "$n" 2>/dev/null || true
		timeout "$rt" dig +short +tries=1 +time="$rt" "@${s}" AAAA "$n" 2>/dev/null || true
	elif command -v host >/dev/null 2>&1; then
		timeout "$rt" host -W "$rt" -t A    "$n" "$s" 2>/dev/null | awk '/has address/{print $NF}' || true
		timeout "$rt" host -W "$rt" -t AAAA "$n" "$s" 2>/dev/null | awk '/IPv6 address/{print $NF}' || true
	elif command -v nslookup >/dev/null 2>&1; then
		timeout "$rt" nslookup -type=A    "$n" "$s" 2>/dev/null | awk '/^Address: /{print $2}' || true
		timeout "$rt" nslookup -type=AAAA "$n" "$s" 2>/dev/null | awk '/^Address: /{print $2}' || true
	else
		echo "nftgeo: RESOLVERS lists '${s}' but no dig/host/nslookup is installed; skipping it" >&2
	fi
}

resolve_via() {
	# $1 resolver ("local" = system getent, or a DNS server IP), $2 name. The three
	# getent databases are combined because none is reliable alone: ahostsv4/v6
	# cover DNS A/AAAA, while "hosts" also returns IPv6-only /etc/hosts entries that
	# getaddrinfo can miss. Raw candidate addresses go to stdout.
	case "$1" in
		local)
			{
				getent_t ahostsv4 "$2" || true
				getent_t ahostsv6 "$2" || true
				getent_t hosts    "$2" || true
			} 2>/dev/null | awk '{print $1}'
			;;
		*)
			dns_query "$1" "$2"
			;;
	esac
}

resolve_host() {
	# $1 hostname. Try each resolver in RESOLVERS order; the first that returns any
	# address wins, so "1.1.1.1 8.8.8.8 local" prefers the public view and falls
	# back to the local/VPN resolver only for names it alone can answer. Results are
	# validated as literal IPs, IPv4-mapped v6 (::ffff:) dropped, and de-duplicated.
	for r in ${RESOLVERS:-local}; do
		c="$(resolve_via "$r" "$1" 2>/dev/null | grep -v '^::ffff:' || true)"
		ok="$({ printf '%s\n' "$c" | grep -E "$IPV4_RE" || true
		        printf '%s\n' "$c" | grep -Ei "$IPV6_RE" || true; } | sort -u)"
		if [ -n "$ok" ]; then printf '%s\n' "$ok"; return 0; fi
	done
	return 0
}

resolve_whitelist_hosts() {
	# Resolve WHITELIST_HOSTS to IPs and append them to the raw whitelist files.
	# Hostnames come from WHITELIST_HOSTS_FILE (one per line, # comments and blank
	# lines skipped) when it has any entry, otherwise from the legacy
	# WHITELIST_HOSTS shell variable (space-separated, sourced from config). The
	# file is the authoritative, UI-managed source once populated; the variable is
	# a fallback/seed so an entry removed in the UI stays removed.
	# State (host<TAB>ip<TAB>last_seen) is kept in WHITELIST_HOSTS_STATE_FILE: a
	# successful lookup replaces a host's addresses, a failed one retains the last
	# known ones for WHITELIST_HOSTS_RETENTION_DAYS so a DNS blip cannot drop
	# access, and stale addresses age out after that window.

	_wl_hosts=""
	if [ -r "$WHITELIST_HOSTS_FILE" ]; then
		while IFS= read -r _line || [ -n "$_line" ]; do
			case "$_line" in
				''|\#*) continue ;;
			esac
			_wl_hosts="$_wl_hosts $_line"
		done < "$WHITELIST_HOSTS_FILE"
	fi
	# Fall back to the legacy variable only when the file has no usable entries.
	[ -n "$(printf '%s' "$_wl_hosts" | tr -d ' ')" ] || _wl_hosts="$WHITELIST_HOSTS"

	# Strip to unique tokens.
	_wl_hosts="$(printf '%s\n' $_wl_hosts | tr ' ' '\n' | grep -v '^$' | sort -u | tr '\n' ' ')"

	[ -n "$_wl_hosts" ] || return 0

	# In render/dry-run mode don't touch DNS or mutate state: reuse the last
	# resolved addresses so validate/plan stay fast and side-effect-free.
	if [ -n "$RENDER_ONLY" ]; then
		[ -s "$WHITELIST_HOSTS_STATE_FILE" ] || return 0
		awk -F'\t' '{print $2}' "$WHITELIST_HOSTS_STATE_FILE" | while read -r ip; do
			[ -n "$ip" ] || continue
			case "$ip" in
				*:*) echo "$ip" >> "${TMP_DIR}/wl6.raw" ;;
				*)   echo "$ip" >> "${TMP_DIR}/wl4.raw" ;;
			esac
		done
		return 0
	fi

	if ! valid_nonnegative_int "$WHITELIST_HOSTS_RETENTION_DAYS"; then
		echo "WHITELIST_HOSTS_RETENTION_DAYS must be a non-negative integer." >&2
		exit 1
	fi

	now="$(date +%s)"
	cutoff="$((now - WHITELIST_HOSTS_RETENTION_DAYS * 86400))"
	new_state="${TMP_DIR}/wlhosts.new"
	: > "$new_state"

	for host in $_wl_hosts; do
		resolved="$(resolve_host "$host" | sort -u)"
		if [ -n "$resolved" ]; then
			printf '%s\n' "$resolved" | while read -r ip; do
				[ -n "$ip" ] && printf '%s\t%s\t%s\n' "$host" "$ip" "$now" >> "$new_state"
			done
		else
			echo "Whitelist host '${host}' did not resolve; retaining last known addresses (if any)." >&2
			if [ -s "$WHITELIST_HOSTS_STATE_FILE" ]; then
				awk -F'\t' -v h="$host" -v cutoff="$cutoff" \
					'$1==h && $3 ~ /^[0-9]+$/ && $3 >= cutoff' \
					"$WHITELIST_HOSTS_STATE_FILE" >> "$new_state"
			fi
		fi
	done

	sort -u "$new_state" -o "$new_state"
	install -m 0644 "$new_state" "$WHITELIST_HOSTS_STATE_FILE"

	awk -F'\t' '{print $2}' "$new_state" | while read -r ip; do
		[ -n "$ip" ] || continue
		case "$ip" in
			*:*) echo "$ip" >> "${TMP_DIR}/wl6.raw" ;;
			*)   echo "$ip" >> "${TMP_DIR}/wl4.raw" ;;
		esac
	done
}

build_whitelist() {
	: > "${TMP_DIR}/wl4.raw"
	: > "${TMP_DIR}/wl6.raw"

	# IP/CIDR entries: WHITELIST_FILE (one per line, # comments and blank lines
	# skipped) is authoritative once it has any entry; otherwise fall back to the
	# legacy WHITELIST shell variable (space-separated, sourced from config). This
	# lets the UI-managed file remove an entry without the config variable
	# re-adding it, while an empty/absent file keeps the legacy behaviour.
	_wl_entries=""
	if [ -r "$WHITELIST_FILE" ]; then
		while IFS= read -r _wl_entry || [ -n "$_wl_entry" ]; do
			case "$_wl_entry" in
				''|\#*) continue ;;
			esac
			_wl_entries="$_wl_entries $_wl_entry"
		done < "$WHITELIST_FILE"
	fi
	[ -n "$(printf '%s' "$_wl_entries" | tr -d ' ')" ] || _wl_entries="$WHITELIST"
	for entry in $_wl_entries; do
		case "$entry" in
			*:*) echo "$entry" >> "${TMP_DIR}/wl6.raw" ;;
			*)   echo "$entry" >> "${TMP_DIR}/wl4.raw" ;;
		esac
	done

	resolve_whitelist_hosts

	sort -u "${TMP_DIR}/wl4.raw" | grep -E "$IPV4_RE" > "${TMP_DIR}/whitelist4.set" || true
	sort -u "${TMP_DIR}/wl6.raw" | grep -Ei "$IPV6_RE" > "${TMP_DIR}/whitelist6.set" || true
}

write_set_elements() {
	file="$1"
	if [ -s "$file" ]; then
		awk 'BEGIN{first=1} { if (!first) printf ",\n"; first=0; printf "\t\t\t%s", $0 } END{ printf "\n" }' "$file"
	fi
}

write_addr_set() {
	name="$1"
	type="$2"
	file="$3"

	# auto-merge lets overlapping/adjacent entries coexist (e.g. an AbuseIPDB
	# single IP inside a feed's CIDR, or a whitelisted host inside a whitelisted
	# subnet); without it nft rejects them as "conflicting intervals".
	printf '\tset %s {\n\t\ttype %s\n\t\tflags interval\n\t\tauto-merge\n' "$name" "$type"
	# When batching a large abuse set, declare it empty here (loaded atomically)
	# and fill it in paced batches after the load - see batch_load_abuse.
	if [ -s "$file" ] && ! { [ "${BATCH_ABUSE:-0}" = 1 ] && [ "$name" != "${name#abuse}" ]; }; then
		printf '\t\telements = {\n'
		write_set_elements "$file"
		printf '\t\t}\n'
	fi
	printf '\t}\n\n'
}

batch_load_abuse() {
	# Fill the abuse sets in paced batches so a huge list doesn't spike the box.
	# Writes progress to ABUSE_LOAD_PROGRESS ("<loaded> <total> <ts>", then "done").
	_bt=0
	for _v in 4 6; do
		_f="${TMP_DIR}/abuse${_v}.set"
		[ -s "$_f" ] && _bt=$((_bt + $(wc -l < "$_f")))
	done
	if [ "$_bt" = 0 ]; then
		nft flush set "$TABLE_FAMILY" "$TABLE_NAME" abuse4 2>/dev/null || true
		nft flush set "$TABLE_FAMILY" "$TABLE_NAME" abuse6 2>/dev/null || true
		rm -f "$ABUSE_LOAD_PROGRESS" 2>/dev/null || true
		return 0
	fi
	echo "warning: loading ${_bt} abuse entries in batches of ${ABUSE_FEEDS_BATCH} (${ABUSE_FEEDS_BATCH_SLEEP}s apart) to keep load low; the blocklist ramps up over ~$((_bt / ABUSE_FEEDS_BATCH * ABUSE_FEEDS_BATCH_SLEEP))s." >&2
	# Flush first so entries dropped from the feed are removed (batch-add can't).
	nft flush set "$TABLE_FAMILY" "$TABLE_NAME" abuse4 2>/dev/null || true
	nft flush set "$TABLE_FAMILY" "$TABLE_NAME" abuse6 2>/dev/null || true
	_done=0
	printf '%s %s %s\n' "$_done" "$_bt" "$(date +%s)" > "$ABUSE_LOAD_PROGRESS" 2>/dev/null || true
	for _v in 4 6; do
		_f="${TMP_DIR}/abuse${_v}.set"
		[ -s "$_f" ] || continue
		rm -f "${TMP_DIR}"/abchunk_* 2>/dev/null || true
		split -l "$ABUSE_FEEDS_BATCH" "$_f" "${TMP_DIR}/abchunk_"
		for _c in "${TMP_DIR}"/abchunk_*; do
			[ -s "$_c" ] || continue
			_el="$(paste -sd, "$_c")"
			[ -n "$_el" ] && nft add element "$TABLE_FAMILY" "$TABLE_NAME" "abuse${_v}" "{ ${_el} }" 2>/dev/null || true
			_done=$((_done + $(wc -l < "$_c")))
			printf '%s %s %s\n' "$_done" "$_bt" "$(date +%s)" > "$ABUSE_LOAD_PROGRESS" 2>/dev/null || true
			sleep "$ABUSE_FEEDS_BATCH_SLEEP"
		done
	done
	printf 'done %s %s\n' "$_bt" "$(date +%s)" > "$ABUSE_LOAD_PROGRESS" 2>/dev/null || true
}

emit_chain() {
	# $1 hook (input|output|forward), $2 address sides for whitelist/abuse
	hook="$1"
	sides="$2"
	# This hook's default policy (accept/drop).
	pol=accept
	case "$hook" in
		input) pol="$DEFAULT_INPUT" ;;
		output) pol="$DEFAULT_OUTPUT" ;;
		forward) pol="$DEFAULT_FORWARD" ;;
	esac
	if ! awk -v h="$hook" 'BEGIN{f=1} $2==h{f=0} END{exit f}' "$RULES_NORM" &&
	   ! awk -v h="$hook" 'BEGIN{f=1} $1==h{f=0} END{exit f}' "$THROTTLE_NORM" &&
	   ! awk -v h="$hook" 'BEGIN{f=1} $1==h{f=0} END{exit f}' "$SYNPROXY_NORM" &&
	   ! { [ "$hook" = forward ] && [ -s "$ZONE_NORM" ]; } &&
	   ! { [ "$hook" = input ] && [ -n "${FORCE_INPUT_CHAIN:-}" ]; } &&
	   [ "$pol" = accept ]; then
		# A default-deny hook must always emit its chain, even with no rules, or
		# the policy has no effect (no hooked chain = no filtering).
		return 0
	fi

	printf '\tchain %s {\n' "$hook"
	printf '\t\ttype filter hook %s priority -100; policy %s;\n' "$hook" "$pol"
	# Baseline hardening (HARDEN): never filter loopback, drop invalid packets.
	if [ -n "$HARDEN" ]; then
		case "$hook" in
			input)  printf '\t\tiifname "lo" counter accept\n' ;;
			output) printf '\t\toifname "lo" counter accept\n' ;;
		esac
		printf '\t\tct state invalid counter drop\n'
	elif [ "$hook" = input ] && [ "$DEFAULT_INPUT" = drop ]; then
		# A default-deny policy must still let loopback through, even without
		# HARDEN, or local services break.
		printf '\t\tiifname "lo" counter accept\n'
	elif [ "$hook" = output ] && [ "$DEFAULT_OUTPUT" = drop ]; then
		printf '\t\toifname "lo" counter accept\n'
	fi
	# Stateful: replies to connections you initiated are always allowed.
	printf '\t\tct state established,related counter accept\n'
	# HARDEN: rate-limit inbound ping so a flood can't drown the host. Drops only
	# the excess (over the rate); NDP/essential ICMPv6 below stay unlimited.
	if [ -n "$HARDEN" ] && [ "$hook" = input ] && [ "$ICMP_RATE" != 0 ]; then
		printf '\t\ticmp type echo-request limit rate over %s burst %s packets counter drop\n' "$ICMP_RATE" "$ICMP_BURST"
		printf '\t\ticmpv6 type echo-request limit rate over %s burst %s packets counter drop\n' "$ICMP_RATE" "$ICMP_BURST"
	fi
	# Keep IPv6 working: NDP and essential ICMPv6 must pass even when v6 is fenced.
	# Always with HARDEN; and unconditionally on any chain whose policy is
	# default-deny even without HARDEN — otherwise a "drop" policy silently kills
	# IPv6 Neighbor Discovery (SLAAC/RA/RS) and breaks IPv6 connectivity.
	if [ -n "$HARDEN" ] || [ "$pol" = drop ]; then
		printf '\t\ticmpv6 type { %s } counter accept\n' "$ICMPV6_ESSENTIAL"
	fi

	# Anti-spoofing (ANTISPOOF): drop packets whose source is not routable
	# back through the arrival interface (reverse-path filter in the firewall).
	# Applied to input and forward chains for the listed interfaces.
	if [ -n "$ANTISPOOF" ] && { [ "$hook" = input ] || [ "$hook" = forward ]; }; then
		for _asi in $ANTISPOOF; do
			case "$_asi" in *[!A-Za-z0-9._@:-]*) echo "bad interface in ANTISPOOF: '$_asi'" >&2; exit 1 ;; esac
			[ -n "$LOG_DROPS" ] && printf '\t\tiifname "%s" meta nfproto ipv4 fib saddr . iif oif 0 %s log prefix "%s:antispoof "%s\n' "$_asi" "$LOG_LIMIT" "$LOG_PREFIX_BASE" "$NFLOG_SUFFIX"
			printf '\t\tiifname "%s" meta nfproto ipv4 fib saddr . iif oif 0 counter drop\n' "$_asi"
		done
	fi

	# Whitelist always wins on every managed port.
	for s in $sides; do
		if [ -s "${TMP_DIR}/whitelist4.set" ]; then
			[ -n "$LOG_WHITELIST" ] && printf '\t\tip %s @whitelist4 %s log prefix "nftgeo-accept:whitelist "%s\n' "$s" "$LOG_LIMIT" "$NFLOG_SUFFIX"
			printf '\t\tip %s @whitelist4 counter accept\n' "$s"
		fi
		if [ -s "${TMP_DIR}/whitelist6.set" ]; then
			[ -n "$LOG_WHITELIST" ] && printf '\t\tip6 %s @whitelist6 %s log prefix "nftgeo-accept:whitelist "%s\n' "$s" "$LOG_LIMIT" "$NFLOG_SUFFIX"
			printf '\t\tip6 %s @whitelist6 counter accept\n' "$s"
		fi
	done

	# SYN-flood protection (synproxy): emit before throttle and allow rules
	# so SYN packets hit synproxy first.  synproxy completes the handshake
	# in-kernel; spoofed SYNs that never reply are dropped automatically.
	if [ -s "$SYNPROXY_NORM" ] && awk -v h="$hook" 'BEGIN{f=1} $1==h{f=0} END{exit f}' "$SYNPROXY_NORM"; then
		awk -v h="$hook" '$1==h' "$SYNPROXY_NORM" | while read -r _sh _port _siface; do
			ifc=""
			[ "$_siface" != "-" ] && ifc="iifname \"${_siface}\" "
			case "$_port" in
				*,*) printf '\t\t%stcp dport { %s } ct state new synproxy mss 1460 wscale 7 counter\n' "$ifc" "$_port" ;;
				*)   printf '\t\t%stcp dport %s ct state new synproxy mss 1460 wscale 7 counter\n' "$ifc" "$_port" ;;
			esac
		done
	fi

	# Reactive throttle (after the whitelist, so whitelisted sources are immune):
	# drop already-banned sources, then rate-limit new connections per source and
	# add offenders to the block set.
	if awk -v h="$hook" 'BEGIN{f=1} $1==h{f=0} END{exit f}' "$THROTTLE_NORM"; then
		printf '\t\tip saddr @throttle_block4 counter drop\n'
		printf '\t\tip6 saddr @throttle_block6 counter drop\n'
		awk -v h="$hook" '$1==h' "$THROTTLE_NORM" | while read -r _h side proto port rate ban iface; do
			ifc="$(if_match "$side" "$iface")"; pre=""; [ -n "$ifc" ] && pre="${ifc} "
			k="$(thr_key "$proto" "$port")"
			m4="$(l4_match "$proto" "$port" 4)"
			m6="$(l4_match "$proto" "$port" 6)"
			printf '\t\t%s%s ct state new add @%s4 { ip saddr limit rate over %s } add @throttle_block4 { ip saddr timeout %s } counter drop\n' "$pre" "$m4" "$k" "$rate" "$ban"
			printf '\t\t%s%s ct state new add @%s6 { ip6 saddr limit rate over %s } add @throttle_block6 { ip6 saddr timeout %s } counter drop\n' "$pre" "$m6" "$k" "$rate" "$ban"
		done
	fi

	# Explicit allow/deny rules, evaluated in FILE ORDER (first match wins), like a
	# classic firewall. The reserved "abuse" target drops the AbuseIPDB blacklist
	# on exactly the proto/port/direction named. There is no automatic
	# deny-by-default: a port is closed only by an explicit "deny ... any" or by
	# DEFAULT_INPUT="drop".
	awk -v h="$hook" '($1=="allow" || $1=="deny") && $2==h' "$RULES_NORM" | while read -r _act _h side proto port geosan iface _rlog meta; do
		lname="${meta%%|*}"; src="${meta#*|}"
		ifc="$(if_match "$side" "$iface")"
		m4="$(l4_match "$proto" "$port" 4)"
		m6="$(l4_match "$proto" "$port" 6)"
		_vd=accept; [ "$_act" = deny ] && _vd=drop
		# Per-rule logging: on when the rule carries "log", or (for a drop) when the
		# global LOG_DROPS is set. Accepts log as nftgeo-accept:, drops nftgeo-drop:.
		_dolog=0; { [ "$_rlog" = 1 ] || { [ "$_vd" = drop ] && [ -n "$LOG_DROPS" ]; }; } && _dolog=1
		_pfx="$LOG_PREFIX_BASE"; [ "$_vd" = accept ] && _pfx="nftgeo-accept"
		_lr="$lname"; [ -z "$_lr" ] && { [ "$_vd" = drop ] && _lr=deny || _lr=allow; }
		if [ "$geosan" = "any" ]; then
			# No address set: match on the proto/port alone (both families).
			pre=""; [ -n "$ifc" ] && pre="${ifc} "
			printed=""
			for m in "$m4" "$m6"; do
				[ -n "$m" ] || continue
				case "$printed" in *"|${m}|"*) continue ;; esac
				printed="${printed}|${m}|"
				mm=""; [ "$m" != any ] && mm="$m "
				[ "$_dolog" = 1 ] && printf '\t\t%s%s%s log prefix "%s:%s "%s\n' "$pre" "$mm" "$LOG_LIMIT" "$_pfx" "$_lr" "$NFLOG_SUFFIX"
				printf '\t\t%s%scounter %s comment "%s"\n' "$pre" "$mm" "$_vd" "$src"
			done
		else
			emit_set_match "$m4" ip  "$side" "$(set_name "$geosan" 4)" "$_vd" "$ifc" "$src" "$lname" "$_rlog"
			emit_set_match "$m6" ip6 "$side" "$(set_name "$geosan" 6)" "$_vd" "$ifc" "$src" "$lname" "$_rlog"
		fi
	done

	# Inter-zone rules (P5): forward-chain accept/deny between named zone
	# interfaces (iifname = source zone, oifname = destination zone). Denies are
	# emitted before allows so an explicit deny wins.
	if [ "$hook" = forward ] && [ -s "$ZONE_NORM" ]; then
		for _verb in deny allow; do
			awk -v v="$_verb" '$1==v' "$ZONE_NORM" | while read -r _za _zs _zd _zp _zport _zg; do
				pre=""
				[ "$_zs" != "-" ] && pre="iifname $(iface_set "$(echo "$_zs" | tr ',' ' ')") "
				[ "$_zd" != "-" ] && pre="${pre}oifname $(iface_set "$(echo "$_zd" | tr ',' ' ')") "
				_vd=accept; [ "$_za" = deny ] && _vd=drop
				if [ "$_zg" = "-" ]; then
					_m="$(zone_l4 "$_zp" "$_zport")"; _mm=""; [ -n "$_m" ] && _mm="${_m} "
					[ "$_vd" = drop ] && [ -n "$LOG_DROPS" ] && printf '\t\t%s%s%s log prefix "%s:zone "%s\n' "$pre" "$_mm" "$LOG_LIMIT" "$LOG_PREFIX_BASE" "$NFLOG_SUFFIX"
					printf '\t\t%s%scounter %s\n' "$pre" "$_mm" "$_vd"
				else
					for _fam in 4 6; do
						_m="$(l4_match "$_zp" "$_zport" "$_fam")"; [ -n "$_m" ] || continue
						_ipv=ip; [ "$_fam" = 6 ] && _ipv=ip6
						_mm=""; [ "$_m" != any ] && _mm="${_m} "
						_gm="${_ipv} saddr @$(set_name "$_zg" "$_fam")"
						[ "$_vd" = drop ] && [ -n "$LOG_DROPS" ] && printf '\t\t%s%s%s %s log prefix "%s:zone "%s\n' "$pre" "$_mm" "$_gm" "$LOG_LIMIT" "$LOG_PREFIX_BASE" "$NFLOG_SUFFIX"
						printf '\t\t%s%s%s counter %s\n' "$pre" "$_mm" "$_gm" "$_vd"
					done
				fi
			done
		done
		# Segment default-deny: drop forwarded traffic between zone interfaces that
		# no rule above allowed (established/related is already accepted above).
		if [ "$SEGMENT_DEFAULT" = deny ] && [ -s "$ZONE_SEG_IF" ]; then
			_allif="$(iface_set "$(sort -u "$ZONE_SEG_IF" | tr '\n' ' ')")"
			[ -n "$LOG_DROPS" ] && printf '\t\tiifname %s oifname %s %s log prefix "%s:segment "%s\n' "$_allif" "$_allif" "$LOG_LIMIT" "$LOG_PREFIX_BASE" "$NFLOG_SUFFIX"
			printf '\t\tiifname %s oifname %s counter drop\n' "$_allif" "$_allif"
		fi
	fi

	# Under default-deny, log what the policy would drop so it shows in the panel
	# (an explicit logged drop just before the implicit "policy drop").
	if [ "$hook" = input ] && [ "$DEFAULT_INPUT" = drop ] && [ -n "$LOG_DROPS" ]; then
		printf '\t\t%s log prefix "%s:default-deny "%s\n' "$LOG_LIMIT" "$LOG_PREFIX_BASE" "$NFLOG_SUFFIX"
		printf '\t\tcounter drop\n'
	fi

	printf '\t}\n'
}

# emit_ingress: the ingress hook chain (stateless early drop, before prerouting/
# conntrack). Whitelist wins first; then the ingress.conf rules, source-based.
# Only emitted when there are ingress rules (inet ingress needs kernel >= 5.10).
emit_ingress() {
	[ -s "$INGRESS_NORM" ] || return 0
	# The ingress hook is per-device. Attach to INGRESS_DEV, or auto-detect the
	# default-route interface. Without a device the hook receives no packets.
	# Accept comma- or space-separated devices (matches how targets/zones/lists
	# are written elsewhere), normalising commas to spaces for word-splitting.
	_idevs="$(printf '%s' "$INGRESS_DEV" | tr ',' ' ')"
	[ -n "$(printf '%s' "$_idevs" | tr -d ' \t')" ] || _idevs="$(ip route show default 2>/dev/null | sed -n 's/.* dev \([^ ]*\).*/\1/p' | head -1)"
	if [ -z "$_idevs" ]; then
		echo "ingress rules present but no INGRESS_DEV set and no default route found; skipping ingress chain." >&2
		return 0
	fi
	# The rules live in one regular chain; each per-device ingress base chain jumps
	# to it (a base chain hooks a single device, so we need one per interface).
	printf '\tchain ingress_rules {\n'
	[ -s "${TMP_DIR}/whitelist4.set" ] && printf '\t\tip saddr @whitelist4 counter accept\n'
	[ -s "${TMP_DIR}/whitelist6.set" ] && printf '\t\tip6 saddr @whitelist6 counter accept\n'
	while read -r _act geosan proto port _ilog meta; do
		lname="${meta%%|*}"; src="${meta#*|}"
		m4="$(l4_match "$proto" "$port" 4)"
		m6="$(l4_match "$proto" "$port" 6)"
		if [ "$geosan" = any ]; then
			printed=""
			for m in "$m4" "$m6"; do
				[ -n "$m" ] || continue
				case "$printed" in *"|${m}|"*) continue ;; esac
				printed="${printed}|${m}|"
				mm=""; [ "$m" != any ] && mm="$m "
				_dolog=0; { [ "$_ilog" = 1 ] || { [ "$_act" = drop ] && [ -n "$LOG_DROPS" ]; }; } && _dolog=1
				_pfx="$LOG_PREFIX_BASE"; [ "$_act" = accept ] && _pfx="nftgeo-accept"
				_lr="$lname"; [ -z "$_lr" ] && _lr="$_act"
				[ "$_dolog" = 1 ] && printf '\t\t%s%s log prefix "%s:%s "%s\n' "$mm" "$LOG_LIMIT" "$_pfx" "$_lr" "$NFLOG_SUFFIX"
				printf '\t\t%scounter %s comment "%s"\n' "$mm" "$_act" "$src"
			done
		else
			emit_set_match "$m4" ip  saddr "$(set_name "$geosan" 4)" "$_act" "" "$src" "$lname" "$_ilog"
			emit_set_match "$m6" ip6 saddr "$(set_name "$geosan" 6)" "$_act" "" "$src" "$lname" "$_ilog"
		fi
	done < "$INGRESS_NORM"
	printf '\t}\n'
	for _idev in $_idevs; do
		case "$_idev" in *[!A-Za-z0-9._@:-]*) echo "bad interface in INGRESS_DEV: '${_idev}'" >&2; exit 1 ;; esac
		_icn="ingress_$(printf '%s' "$_idev" | tr -cs 'a-zA-Z0-9' '_')"
		printf '\tchain %s {\n' "$_icn"
		printf '\t\ttype filter hook ingress device "%s" priority -300; policy accept;\n' "$_idev"
		printf '\t\tjump ingress_rules\n'
		printf '\t}\n'
	done
}

generate() {
	{
		# Atomic replace: create the table if missing, delete it, then rebuild it
		# from scratch in a single nft -f load, so the rules are never absent.
		printf 'table %s %s\n' "$TABLE_FAMILY" "$TABLE_NAME"
		printf 'delete table %s %s\n' "$TABLE_FAMILY" "$TABLE_NAME"
		printf 'table %s %s {\n' "$TABLE_FAMILY" "$TABLE_NAME"

		write_addr_set "whitelist4" "ipv4_addr" "${TMP_DIR}/whitelist4.set"
		write_addr_set "whitelist6" "ipv6_addr" "${TMP_DIR}/whitelist6.set"
		write_addr_set "abuse4" "ipv4_addr" "${TMP_DIR}/abuse4.set"
		write_addr_set "abuse6" "ipv6_addr" "${TMP_DIR}/abuse6.set"
		while read -r geosan; do
			[ -n "$geosan" ] || continue
			write_addr_set "g_${geosan}4" "ipv4_addr" "${TMP_DIR}/g_${geosan}.v4"
			write_addr_set "g_${geosan}6" "ipv6_addr" "${TMP_DIR}/g_${geosan}.v6"
		done < "$GEO_FINAL"

		# Reactive throttle: a shared block set (offenders, ban-timeout at add) plus
		# one per-port meter set that carries the per-source rate limiter.
		if [ -s "$THROTTLE_NORM" ]; then
			printf '\t\tset throttle_block4 { type ipv4_addr; flags dynamic,timeout; }\n'
			printf '\t\tset throttle_block6 { type ipv6_addr; flags dynamic,timeout; }\n'
			awk '{print $3" "$4}' "$THROTTLE_NORM" | sort -u | while read -r _p _pt; do
				k="$(thr_key "$_p" "$_pt")"
				printf '\t\tset %s4 { type ipv4_addr; flags dynamic,timeout; timeout %s; }\n' "$k" "$THROTTLE_BAN"
				printf '\t\tset %s6 { type ipv6_addr; flags dynamic,timeout; timeout %s; }\n' "$k" "$THROTTLE_BAN"
			done
		fi

		emit_ingress
		emit_chain "input" "saddr"
		emit_chain "output" "daddr"
		emit_chain "forward" "saddr daddr"

		# Ingress NAT (P4): a dest-NAT prerouting chain for port-forwarding,
		# emitted only when a dnat rule exists.
		if grep -q '^dnat ' "$NAT_NORM" 2>/dev/null; then
			printf '\tchain prerouting {\n'
			printf '\t\ttype nat hook prerouting priority dstnat; policy accept;\n'
			grep '^dnat ' "$NAT_NORM" | while read -r _k _dproto _dport _dip _dtport _diface _dgeo; do
				_pre=""
				[ "$_diface" = "-" ] || _pre="iifname \"${_diface}\" "
				# inet table: dnat needs the family (ip/ip6) spelled out.
				case "$_dip" in
					*:*) _fam="ip6"; _fnum=6; [ "$_dtport" = "-" ] && _to="$_dip" || _to="[${_dip}]:${_dtport}" ;;
					*)   _fam="ip";  _fnum=4; [ "$_dtport" = "-" ] && _to="$_dip" || _to="${_dip}:${_dtport}" ;;
				esac
				# Optional source-geo restriction: the DNAT'd packet is the target's
				# family, so match the client against the same-family geo set.
				_gm=""; [ "${_dgeo:--}" = "-" ] || _gm="${_fam} saddr @$(set_name "$_dgeo" "$_fnum") "
				printf '\t\t%s%s%s dport %s counter dnat %s to %s\n' "$_pre" "$_gm" "$_dproto" "$_dport" "$_fam" "$_to"
			done
			printf '\t}\n'
		fi

		# Egress NAT (P3): a source-NAT postrouting chain, emitted only when a
		# masquerade/snat rule exists (so the filter-only case is unchanged).
		if grep -Eq '^(masquerade|snat) ' "$NAT_NORM" 2>/dev/null; then
			printf '\tchain postrouting {\n'
			printf '\t\ttype nat hook postrouting priority srcnat; policy accept;\n'
			while read -r _kind _wan _lan _ip; do
				# Optional inbound (LAN) interface scoping.
				_pre=""; [ "${_lan:--}" = "-" ] || _pre="iifname \"${_lan}\" "
				case "$_kind" in
					masquerade) printf '\t\t%soifname "%s" counter masquerade\n' "$_pre" "$_wan" ;;
					snat)
						# inet table: snat needs the family (ip/ip6) spelled out.
						case "$_ip" in
							*:*) printf '\t\t%soifname "%s" counter snat ip6 to %s\n' "$_pre" "$_wan" "$_ip" ;;
							*)   printf '\t\t%soifname "%s" counter snat ip to %s\n' "$_pre" "$_wan" "$_ip" ;;
						esac
						;;
				esac
			done < "$NAT_NORM"
			printf '\t}\n'
		fi

		printf '}\n'
	} > "${TMP_DIR}/nftgeo.nft"
}

parse_rules

# Anti-lockout: under default-deny, warn when nothing obviously admits inbound
# connections (no whitelist and no "allow in" rule) - established/related and
# loopback still pass, but a new SSH session would be dropped.
if [ "$DEFAULT_INPUT" = drop ] &&
	[ -z "${WHITELIST:-}${WHITELIST_HOSTS:-}" ] &&
	! awk '$1=="allow" && $2=="input"{f=1} END{exit !f}' "$RULES_NORM"; then
	echo "warning: DEFAULT_INPUT=drop but no WHITELIST and no inbound 'allow in' rule; new connections (incl. SSH) will be dropped. Add an allow/whitelist and deploy behind the deadman." >&2
fi

# Sequential model: a geo-restricted "allow in" no longer auto-closes its port
# (deny-by-default was removed). With DEFAULT_INPUT=accept, such a port is open
# to every other source unless a catch-all "deny in <proto> <port> any" follows.
# Warn per port so it is not left open by accident.
if [ "$DEFAULT_INPUT" != drop ]; then
	awk '
		$2=="input" && $1=="allow" && $6!="any" { a[$4" "$5]=1 }
		$2=="input" && $1=="deny"  && $6=="any" { d[$4" "$5]=1 }
		END { for (k in a) if (!(k in d)) print k }
	' "$RULES_NORM" | while read -r _wp _wpt; do
		[ -n "$_wp" ] || continue
		echo "warning: '${_wp} ${_wpt}' has a geo-restricted 'allow in' but no catch-all 'deny in ${_wp} ${_wpt} any'; with DEFAULT_INPUT=accept the port stays open to all other sources. Add the deny, or set DEFAULT_INPUT=\"drop\"." >&2
	done
fi

# NAT / forwarding needs IP forwarding enabled; warn (don't manage the sysctl).
if { [ -s "$NAT_NORM" ] || [ -s "$ZONE_NORM" ] || awk '$2=="forward"{f=1} END{exit !f}' "$RULES_NORM" 2>/dev/null; } &&
	[ -r /proc/sys/net/ipv4/ip_forward ] && [ "$(cat /proc/sys/net/ipv4/ip_forward 2>/dev/null)" = 0 ]; then
	echo "warning: NAT/forward rules are present but net.ipv4.ip_forward=0; enable it (sysctl net.ipv4.ip_forward=1) for routing to work." >&2
fi

ensure_zones
build_geo_sets
# Only hit the AbuseIPDB API when a rule actually targets "abuse"; otherwise the
# sets stay empty (their files are created here so the rest of the run still has
# them to read and install).
: > "${TMP_DIR}/abuse4.set"
: > "${TMP_DIR}/abuse6.set"
if [ -z "$RENDER_ONLY" ] && awk '$6=="abuse"{found=1} END{exit !found}' "$RULES_NORM"; then
	fetch_abuseipdb
	fetch_abuse_feeds
fi
# Always scrub: covers fresh, cached, and retained abuse data alike.
scrub_abuse
build_whitelist

# Decide whether to batch-load the abuse set: declared empty in the atomic load,
# then filled in paced batches after (keeps a huge list from spiking the box).
BATCH_ABUSE=0
if [ -z "$RENDER_ONLY" ] && [ "$ABUSE_FEEDS_BATCH" -gt 0 ] 2>/dev/null; then
	_abtot=0
	[ -s "${TMP_DIR}/abuse4.set" ] && _abtot=$((_abtot + $(wc -l < "${TMP_DIR}/abuse4.set")))
	[ -s "${TMP_DIR}/abuse6.set" ] && _abtot=$((_abtot + $(wc -l < "${TMP_DIR}/abuse6.set")))
	[ "$_abtot" -gt "$ABUSE_FEEDS_BATCH" ] && BATCH_ABUSE=1
fi
generate

# Validate the generated ruleset against the kernel. Skippable for offline
# golden/text tests (NFTGEO_SKIP_NFT_CHECK=1) or when nft is absent; a real load
# (below) always requires nft, so this only relaxes render-only runs.
if [ -z "${NFTGEO_SKIP_NFT_CHECK:-}" ] && command -v nft >/dev/null 2>&1; then
	nft_try -c -f "${TMP_DIR}/nftgeo.nft"
elif [ -z "$RENDER_ONLY" ]; then
	echo "nft not found; cannot load the ruleset" >&2
	exit 1
fi

if [ -n "$RENDER_ONLY" ]; then
	[ -n "$RENDER_OUT" ] && install -m 0644 "${TMP_DIR}/nftgeo.nft" "$RENDER_OUT"
	printf 'nftgeo %s validated %s/%s: rules=%s geo_groups=%s (render only, not loaded)\n' \
		"$NFTGEO_VERSION" "$TABLE_FAMILY" "$TABLE_NAME" \
		"$(wc -l < "$RULES_NORM")" "$(wc -l < "$GEO_FINAL")"
	exit 0
fi

# Write status.json for the dashboard: API key state, fetch timestamps,
# warnings. Called on both the loaded and the unchanged exit paths so the
# dashboard sees fresh data even when the ruleset itself did not change.
write_status() {
	_now=$(date -u +%s)
	# Persist fetch timestamps for cross-run freshness: only updated on a
	# fresh download; retained-state runs keep the previous value.
	_abuse_fetched=""
	[ -f "${TMP_DIR}/abuse_fetched_at" ] && _abuse_fetched=$(cat "${TMP_DIR}/abuse_fetched_at")
	[ -n "$_abuse_fetched" ] && echo "$_abuse_fetched" > "$ABUSE_FETCH_TS"
	[ -f "$ABUSE_FETCH_TS" ] && _abuse_fetched=$(cat "$ABUSE_FETCH_TS")
	_geo_fetched=""
	[ -f "${TMP_DIR}/geo_fetched_at" ] && _geo_fetched=$(cat "${TMP_DIR}/geo_fetched_at")
	[ -n "$_geo_fetched" ] && echo "$_geo_fetched" > "$GEO_FETCH_TS"
	[ -f "$GEO_FETCH_TS" ] && _geo_fetched=$(cat "$GEO_FETCH_TS")
	# No recorded download yet (zones served from cache since before the
	# timestamp existed): estimate from the newest zone cache file's mtime so
	# the panel does not claim "not yet fetched" while geo data is working.
	# Not persisted — a real download will set GEO_FETCH_TS.
	if [ -z "$_geo_fetched" ] && [ -d "$ZONE_DIR" ]; then
		_geo_fetched=$(find "$ZONE_DIR" \( -name '*.v4' -o -name '*.v6' \) -type f \
			-exec stat -c %Y {} + 2>/dev/null | sort -n | tail -1) || true
	fi
	_abuse_has_key="false"
	[ -n "${ABUSEIPDB_API_KEY:-}" ] && _abuse_has_key="true"
	_abuse_rule="false"
	awk '$6=="abuse"{found=1} END{exit !found}' "$RULES_NORM" && _abuse_rule="true"
	# Warnings as a JSON array: escape backslashes and quotes, quote each
	# line, join with commas.
	_warnings_json="[]"
	if [ -s "$WARN_FILE" ]; then
		_warnings_json="[$(sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' -e 's/^/"/' -e 's/$/"/' "$WARN_FILE" | paste -sd, -)]"
	fi
	cat > "$STATUS_FILE" <<STATUS_EOF
{"version":"$NFTGEO_VERSION","timestamp":$_now,"abuse":{"api_key_present":$_abuse_has_key,"rule_active":$_abuse_rule,"fetched_at":${_abuse_fetched:-null}},"geo":{"fetched_at":${_geo_fetched:-null}},"warnings":$_warnings_json}
STATUS_EOF
}

# No-op: if the render is byte-identical to what is already loaded, skip the
# reload so per-rule counters are preserved (a flush/reload would zero them).
# Guarded by a live-table check so a fresh boot (file present, table absent)
# still loads.
if [ -f "$NFT_FILE" ] && cmp -s "${TMP_DIR}/nftgeo.nft" "$NFT_FILE" \
		&& nft list table "$TABLE_FAMILY" "$TABLE_NAME" >/dev/null 2>&1; then
	# The rendered ruleset is unchanged, but when batching the abuse set lives
	# outside the file (declared empty), so refresh it in paced batches anyway.
	[ "${BATCH_ABUSE:-0}" = 1 ] && batch_load_abuse
	write_status
	printf 'nftgeo %s unchanged %s/%s; ruleset not reloaded (counters preserved).\n' \
		"$NFTGEO_VERSION" "$TABLE_FAMILY" "$TABLE_NAME"
	exit 0
fi

install -m 0644 "${TMP_DIR}/nftgeo.nft" "$NFT_FILE"
nft_try -f "$NFT_FILE"
# Fill the (empty-loaded) abuse set in paced batches after the atomic load.
[ "${BATCH_ABUSE:-0}" = 1 ] && batch_load_abuse

install -m 0644 "${TMP_DIR}/whitelist4.set" "${STATE_DIR}/whitelist4.set"
install -m 0644 "${TMP_DIR}/whitelist6.set" "${STATE_DIR}/whitelist6.set"
install -m 0644 "${TMP_DIR}/abuse4.set" "${STATE_DIR}/abuse4.set"
install -m 0644 "${TMP_DIR}/abuse6.set" "${STATE_DIR}/abuse6.set"
[ -f "${TMP_DIR}/abuseipdb.tsv" ] && install -m 0644 "${TMP_DIR}/abuseipdb.tsv" "$ABUSEIPDB_STATE_FILE"

printf 'nftgeo %s loaded %s/%s: rules=%s geo_groups=%s whitelist4=%s whitelist6=%s abuse4=%s abuse6=%s\n' \
	"$NFTGEO_VERSION" "$TABLE_FAMILY" "$TABLE_NAME" \
	"$(wc -l < "$RULES_NORM")" \
	"$(wc -l < "$GEO_FINAL")" \
	"$(wc -l < "${TMP_DIR}/whitelist4.set")" \
	"$(wc -l < "${TMP_DIR}/whitelist6.set")" \
	"$(wc -l < "${TMP_DIR}/abuse4.set")" \
	"$(wc -l < "${TMP_DIR}/abuse6.set")"

write_status
